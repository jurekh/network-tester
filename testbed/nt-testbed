#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["pyyaml"]
# ///
"""nt-testbed: nested-virtualization testbed for network-tester (design D18).

The whole testbed lives inside one outer LXD VM. Inside it: MAAS (region+rack
snap with maas-test-db), an inner LXD registered as a MAAS VM host that
composes the node VMs, and Open vSwitch bridges acting as ToR switches.
The host needs only LXD and uv; `nt-testbed down` removes all testbed state.

Subcommands: up, down, status, shell, verify <stage>, fault <name> [args],
fault clear. Configuration lives in topology.yaml next to this script.
"""

import argparse
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import time
from pathlib import Path

import yaml

TESTBED_DIR = Path(__file__).resolve().parent
REPO_ROOT = TESTBED_DIR.parent
CONFIG = yaml.safe_load((TESTBED_DIR / "topology.yaml").read_text())

VM = CONFIG["vm"]["name"]
PXE = CONFIG["pxe"]
MAAS_CFG = CONFIG["maas"]
MAAS_URL = f"http://{PXE['gateway']}:5240/MAAS"
VM_TREE = "/root/network-tester"

SYNC_EXCLUDES = [
    ".git",
    ".venv",
    "charm/.venv",
    ".pytest_cache",
    ".ruff_cache",
    "__pycache__",
]


def log(msg):
    print(f"[{time.strftime('%H:%M:%S')}] {msg}", flush=True)


def fatal(msg):
    log(f"FATAL: {msg}")
    sys.exit(1)


def host_run(args, check=True, capture=False, cwd=None):
    result = subprocess.run(args, check=False, text=True, capture_output=capture, cwd=cwd)
    if check and result.returncode != 0:
        fatal(
            f"command failed ({result.returncode}): {shlex.join(args)}\n"
            f"{(result.stderr or '') if capture else ''}"
        )
    return result


def vm_run(script, check=True, capture=False):
    """Run a bash script inside the testbed VM."""
    return host_run(["lxc", "exec", VM, "--", "bash", "-c", script], check=check, capture=capture)


def vm_out(script, check=True):
    return vm_run(script, check=check, capture=True).stdout.strip()


def vm_ok(script):
    return vm_run(script, check=False, capture=True).returncode == 0


def maas_json(cmd, check=True):
    """Run a maas CLI command inside the VM and parse its JSON output."""
    result = vm_run(f"maas {MAAS_CFG['admin_user']} {cmd}", check=check, capture=True)
    if result.returncode != 0:
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        if check:
            fatal(f"maas {cmd}: expected JSON, got:\n{result.stdout[:2000]}")
        return None


def wait_for(desc, predicate, timeout, interval=10):
    log(f"waiting for {desc} (timeout {timeout}s)")
    deadline = time.time() + timeout
    while time.time() < deadline:
        result = predicate()
        if result:
            return result
        time.sleep(interval)
    fatal(f"timed out waiting for {desc}")


def expected_nodes():
    nodes = []
    for rack in CONFIG["racks"].values():
        nodes.extend(rack["nodes"])
    return nodes


# --- up steps ----------------------------------------------------------------


def vm_exists():
    result = host_run(["lxc", "list", VM, "--format", "json"], capture=True)
    return any(i["name"] == VM for i in json.loads(result.stdout))


def ensure_vm():
    if vm_exists():
        log(f"VM {VM} already exists")
        host_run(["lxc", "start", VM], check=False, capture=True)
    else:
        cfg = CONFIG["vm"]
        log(f"launching VM {VM} ({cfg['cpu']} CPU, {cfg['memory']}, {cfg['disk']} disk)")
        host_run(
            [
                "lxc",
                "launch",
                cfg["image"],
                VM,
                "--vm",
                "-c",
                f"limits.cpu={cfg['cpu']}",
                "-c",
                f"limits.memory={cfg['memory']}",
                "-d",
                f"root,size={cfg['disk']}",
            ]
        )
    wait_for(
        "VM agent",
        lambda: (
            host_run(["lxc", "exec", VM, "--", "true"], check=False, capture=True).returncode == 0
        ),
        timeout=300,
        interval=5,
    )
    vm_run("cloud-init status --wait >/dev/null || true")
    if not vm_ok("test -e /dev/kvm"):
        fatal(
            "nested KVM is not available inside the testbed VM (/dev/kvm missing); "
            "the host must support nested virtualization"
        )
    log("VM is up with nested KVM available")


def ensure_packages():
    maas_channel = MAAS_CFG.get("channel")
    for snap, channel, args in (
        ("maas-test-db", maas_channel, ""),
        ("maas", maas_channel, ""),
        ("lxd", None, ""),
        ("astral-uv", None, "--classic"),
    ):
        if vm_ok(f"snap list {snap} >/dev/null 2>&1"):
            if channel:
                tracking = vm_out(f"snap list {snap} | awk 'NR==2 {{print $4}}'")
                if tracking != channel:
                    log(
                        f"note: snap {snap} tracks {tracking} but topology.yaml wants "
                        f"{channel}; run `nt-testbed down && nt-testbed up` to rebuild"
                    )
            continue
        flag = f" --channel={channel}" if channel else ""
        log(f"installing snap {snap}{flag.replace('=', ' ')}")
        vm_run(f"snap install {snap}{flag} {args}")
    if not vm_ok("dpkg -s openvswitch-switch >/dev/null 2>&1"):
        log("installing openvswitch-switch")
        vm_run("apt-get update -q && apt-get install -qy openvswitch-switch")


def ensure_bridge():
    bridge, cidr, gateway = PXE["bridge"], PXE["cidr"], PXE["gateway"]
    vm_run(f"ovs-vsctl --may-exist add-br {bridge}")
    vm_run(
        f"ip addr replace {gateway}/{cidr.split('/')[1]} dev {bridge} && ip link set {bridge} up"
    )
    # NAT so composed nodes can reach the internet via the testbed VM
    # (not needed for commissioning, but required when charms apt-install).
    vm_run("sysctl -qw net.ipv4.ip_forward=1")
    vm_run(
        f"iptables -t nat -C POSTROUTING -s {cidr} ! -d {cidr} -j MASQUERADE 2>/dev/null"
        f" || iptables -t nat -A POSTROUTING -s {cidr} ! -d {cidr} -j MASQUERADE"
    )
    log(f"OVS bridge {bridge} up at {gateway} with NAT for {cidr}")


def ensure_maas():
    if not vm_ok("maas status >/dev/null 2>&1"):
        log("initialising MAAS region+rack with maas-test-db")
        vm_run(f"maas init region+rack --database-uri maas-test-db:/// --maas-url {MAAS_URL}")
    wait_for(
        "MAAS API",
        lambda: vm_ok(f"curl -fsS {MAAS_URL}/api/2.0/version/ >/dev/null"),
        timeout=300,
        interval=10,
    )
    user = MAAS_CFG["admin_user"]
    if not vm_ok(f"maas apikey --username {user} >/dev/null 2>&1"):
        log(f"creating MAAS admin user {user}")
        vm_run(
            f"maas createadmin --username {user} "
            f"--password {MAAS_CFG['admin_password']} "
            f"--email {MAAS_CFG['admin_email']}"
        )
    if not vm_ok(f"maas list | grep -q '^{user} '"):
        vm_run(f'maas login {user} {MAAS_URL} "$(maas apikey --username {user})"')
    log("MAAS is initialised and the admin profile is logged in")


def ensure_subnet_dhcp():
    rack_controllers = wait_for(
        "rack controller registration",
        lambda: maas_json("rack-controllers read"),
        timeout=600,
        interval=15,
    )
    rack_id = rack_controllers[0]["system_id"]

    cidr = PXE["cidr"]
    subnet = wait_for(
        f"subnet {cidr} discovery",
        lambda: next((s for s in maas_json("subnets read") if s["cidr"] == cidr), None),
        timeout=300,
        interval=10,
    )
    if subnet.get("gateway_ip") != PXE["gateway"]:
        maas_json(f"subnet update {subnet['id']} gateway_ip={PXE['gateway']}")

    ranges = maas_json("ipranges read")
    start = PXE["dhcp_range"]["start"]
    end = PXE["dhcp_range"]["end"]
    if not any(r["start_ip"] == start for r in ranges):
        log(f"creating dynamic DHCP range {start}-{end}")
        maas_json(f"ipranges create type=dynamic start_ip={start} end_ip={end}")

    vlan = subnet["vlan"]
    if not vlan["dhcp_on"]:
        log(f"enabling MAAS DHCP on fabric {vlan['fabric']} vid {vlan['vid']}")
        maas_json(
            f"vlan update {vlan['fabric_id']} {vlan['vid']} dhcp_on=true primary_rack={rack_id}"
        )
    log("PXE subnet and DHCP configured")


def ensure_images():
    resources = maas_json("boot-resources read")
    if not any(r["name"].startswith("ubuntu/") and r["type"] == "Synced" for r in resources):
        log("starting boot image import (this can take a while)")
        maas_json("boot-resources import", check=False)
        time.sleep(15)
    wait_for(
        "boot image import to finish",
        lambda: (
            maas_json("boot-resources is-importing") is False
            and any(
                r["name"].startswith("ubuntu/") and r["type"] == "Synced"
                for r in maas_json("boot-resources read")
            )
        ),
        timeout=3600,
        interval=30,
    )

    def rack_synced():
        racks = maas_json("rack-controllers read")
        images = maas_json(
            f"rack-controller list-boot-images {racks[0]['system_id']}", check=False
        )
        return images is not None and images.get("status") == "synced"

    wait_for("rack controller image sync", rack_synced, timeout=900, interval=20)
    log("boot images imported and synced to the rack controller")


def ensure_inner_lxd():
    vm_run("lxd waitready --timeout 120")
    if not vm_ok("lxc storage show default >/dev/null 2>&1"):
        vm_run("lxc storage create default dir")
    if not vm_ok("lxc profile device get default root pool >/dev/null 2>&1"):
        vm_run("lxc profile device add default root disk path=/ pool=default")
    bridge = PXE["bridge"]
    parent = vm_run(
        "lxc profile device get default eth0 parent", check=False, capture=True
    ).stdout.strip()
    if parent != bridge:
        vm_run("lxc profile device remove default eth0 2>/dev/null || true")
        vm_run(f"lxc profile device add default eth0 nic nictype=bridged parent={bridge}")
    address = vm_out("lxc config get core.https_address")
    if address != f"{PXE['gateway']}:8443":
        vm_run(f"lxc config set core.https_address {PXE['gateway']}:8443")
    log("inner LXD initialised (default profile on the PXE bridge)")


def ensure_vm_host():
    name = MAAS_CFG["vm_host_name"]
    hosts = maas_json("vm-hosts read")
    if any(h["name"] == name for h in hosts):
        log(f"VM host {name} already registered")
        return
    token = vm_out("lxc config trust add --name maas --quiet")
    token = token.splitlines()[-1].strip()
    log(f"registering inner LXD as MAAS VM host {name}")
    maas_json(
        f"vm-hosts create type=lxd power_address={PXE['gateway']}:8443 "
        f"project=default name={name} password={token}"
    )


def ensure_machines():
    name = MAAS_CFG["vm_host_name"]
    host_id = next(h["id"] for h in maas_json("vm-hosts read") if h["name"] == name)
    machines = maas_json("machines read")
    existing = {m["hostname"] for m in machines}
    for node in expected_nodes():
        if node["hostname"] in existing:
            continue
        log(
            f"composing {node['hostname']} "
            f"({node['cpu']} CPU, {node['memory_mib']} MiB, {node['disk_gib']} GiB)"
        )
        maas_json(
            f"vm-host compose {host_id} cores={node['cpu']} "
            f"memory={node['memory_mib']} hostname={node['hostname']} "
            f"storage=main:{node['disk_gib']}"
        )

    expected = {n["hostname"] for n in expected_nodes()}

    def all_ready():
        machines = maas_json("machines read")
        states = {m["hostname"]: m["status_name"] for m in machines if m["hostname"] in expected}
        failed = {h: s for h, s in states.items() if s.startswith("Failed")}
        if failed:
            fatal(f"commissioning failed: {failed}")
        log(f"machine states: {states}")
        return len(states) == len(expected) and all(s == "Ready" for s in states.values())

    wait_for("all composed machines to reach Ready", all_ready, timeout=2400, interval=30)
    log("all composed machines are Ready")


JUJU_CONTROLLER = "nt"
MAAS_CLOUD = "maas-testbed"


def ensure_juju():
    """Bootstrap a Juju controller on the inner LXD and register the MAAS cloud.

    The controller container attaches to the management/PXE bridge through the
    inner LXD default profile, so MAAS-deployed nodes reach the controller API
    without traversing the data fabric, and the controller stays outside the
    topology under test (design D18). charmcraft is installed so the charm can
    be packed inside the VM when the host lacks charmcraft.
    """
    for snap, args in (("juju", ""), ("charmcraft", "--classic")):
        if not vm_ok(f"snap list {snap} >/dev/null 2>&1"):
            log(f"installing snap {snap}")
            vm_run(f"snap install {snap} {args}")
    # the strictly confined juju snap cannot create this directory itself
    vm_run("mkdir -p /root/.local/share/juju")

    controllers = vm_run("juju controllers --format json", check=False, capture=True)
    have_controller = False
    if controllers.returncode == 0 and controllers.stdout.strip():
        parsed = json.loads(controllers.stdout)
        have_controller = JUJU_CONTROLLER in (parsed.get("controllers") or {})
    if not have_controller:
        log(f"bootstrapping Juju controller {JUJU_CONTROLLER} on the inner LXD")
        vm_run(f"juju bootstrap localhost {JUJU_CONTROLLER}")

    def controller_json(cmd, key):
        result = vm_run(
            f"juju {cmd} --controller {JUJU_CONTROLLER} --format json", check=False, capture=True
        )
        if result.returncode != 0 or not result.stdout.strip():
            return {}
        parsed = json.loads(result.stdout)
        # `juju clouds` returns cloud names at the top level; `juju
        # credentials` nests them under a wrapper key
        return parsed.get(key, parsed) or {}

    if MAAS_CLOUD not in controller_json("clouds", "clouds"):
        log(f"registering testbed MAAS as Juju cloud {MAAS_CLOUD}")
        cloud_yaml = (
            f"clouds:\n  {MAAS_CLOUD}:\n    type: maas\n"
            f"    auth-types: [oauth1]\n    endpoint: {MAAS_URL}\n"
        )
        vm_run(f"cat > /root/nt-cloud.yaml <<'EOF'\n{cloud_yaml}EOF")
        vm_run(f"juju add-cloud {MAAS_CLOUD} -f /root/nt-cloud.yaml --client || true")
        vm_run(
            f"juju add-cloud {MAAS_CLOUD} -f /root/nt-cloud.yaml --controller {JUJU_CONTROLLER}"
        )
    if MAAS_CLOUD not in controller_json("credentials", "controller-credentials"):
        log(f"adding MAAS credential for cloud {MAAS_CLOUD}")
        key = vm_out(f"maas apikey --username {MAAS_CFG['admin_user']}")
        cred_yaml = (
            f"credentials:\n  {MAAS_CLOUD}:\n    admin:\n"
            f"      auth-type: oauth1\n      maas-oauth: {key}\n"
        )
        vm_run(f"cat > /root/nt-cred.yaml <<'EOF'\n{cred_yaml}EOF")
        # add-credential refuses when a client-local copy already exists, so
        # clear any local copy and add straight to the controller
        vm_run(f"juju remove-credential {MAAS_CLOUD} admin --client 2>/dev/null || true")
        vm_run(
            f"juju add-credential {MAAS_CLOUD} -f /root/nt-cred.yaml "
            f"--controller {JUJU_CONTROLLER}"
        )
    log(f"Juju controller {JUJU_CONTROLLER} is up with cloud {MAAS_CLOUD} registered")


def ensure_charm_packed():
    """Pack the charm (host charmcraft preferred, VM fallback); return its filename."""
    charm_dir = REPO_ROOT / "charm"
    if shutil.which("charmcraft"):
        log("packing charm on the host")
        host_run(["charmcraft", "pack"], cwd=str(charm_dir))
        charms = sorted(charm_dir.glob("*.charm"))
        if not charms:
            fatal("charmcraft pack produced no .charm file")
        return charms[0].name
    log("host has no charmcraft; packing inside the testbed VM (destructive mode)")
    sync_tree()
    vm_run(f"cd {VM_TREE}/charm && charmcraft pack --destructive-mode")
    name = vm_out(f"ls {VM_TREE}/charm/*.charm | head -1")
    if not name:
        fatal("charmcraft pack inside the VM produced no .charm file")
    return Path(name).name


def sync_tree():
    log(f"syncing working tree to {VM}:{VM_TREE}")
    # recreate the tree so host-side deletions propagate; uv recreates the
    # venvs from its cache in seconds
    vm_run(f"rm -rf {VM_TREE} && mkdir -p {VM_TREE}")
    excludes = [f"--exclude={e}" for e in SYNC_EXCLUDES]
    tar_out = subprocess.Popen(
        ["tar", "-C", str(REPO_ROOT), *excludes, "-cf", "-", "."],
        stdout=subprocess.PIPE,
    )
    untar = subprocess.run(
        ["lxc", "exec", VM, "--", "tar", "-C", VM_TREE, "-xf", "-"],
        stdin=tar_out.stdout,
    )
    tar_out.wait()
    if tar_out.returncode != 0 or untar.returncode != 0:
        fatal("working tree sync failed")
    vm_run(f"cd {VM_TREE} && uv sync --quiet")
    log("working tree synced and uv venv created inside the VM")


def vm_host_address():
    """Return the testbed VM's host-side IPv4 address (on the LXD NAT bridge)."""
    result = host_run(["lxc", "list", VM, "--format", "json"], capture=True)
    instances = [i for i in json.loads(result.stdout) if i["name"] == VM]
    if not instances or not instances[0].get("state"):
        return None
    for name, net in (instances[0]["state"].get("network") or {}).items():
        if name == "lo":
            continue
        for addr in net.get("addresses", []):
            if addr["family"] == "inet" and not addr["address"].startswith("10.100."):
                return addr["address"]
    return None


def report_ui_address():
    ip = vm_host_address()
    if ip:
        log(
            f"MAAS UI reachable from the host at http://{ip}:5240/MAAS "
            f"({MAAS_CFG['admin_user']}/{MAAS_CFG['admin_password']})"
        )
    else:
        log("note: could not determine the VM host-side address for the MAAS UI")


def cmd_up():
    ensure_vm()
    ensure_packages()
    ensure_bridge()
    ensure_maas()
    ensure_subnet_dhcp()
    ensure_images()
    ensure_inner_lxd()
    ensure_vm_host()
    ensure_machines()
    sync_tree()
    ensure_juju()
    report_ui_address()
    log("testbed is up")


# --- other subcommands -------------------------------------------------------


def cmd_down():
    if vm_exists():
        log(f"deleting VM {VM}")
        host_run(["lxc", "delete", "--force", VM])
    else:
        log(f"VM {VM} does not exist")
    leftovers = []
    if vm_exists():
        leftovers.append(f"VM {VM} still present")
    for kind in ("profile", "network"):
        result = host_run(["lxc", kind, "list", "--format", "json"], capture=True)
        for item in json.loads(result.stdout):
            if item["name"].startswith("nt-") or item["name"] == PXE["bridge"]:
                leftovers.append(f"host {kind} {item['name']}")
    if leftovers:
        fatal("host-side leftovers found: " + ", ".join(leftovers))
    log("testbed removed; no host-side leftovers")


def cmd_status():
    result = host_run(["lxc", "list", VM, "--format", "json"], capture=True)
    instances = [i for i in json.loads(result.stdout) if i["name"] == VM]
    if not instances:
        log(f"VM {VM} does not exist (run `nt-testbed up`)")
        return
    log(f"VM {VM}: {instances[0]['status']}")
    if instances[0]["status"] != "Running":
        return
    if not vm_ok("maas status >/dev/null 2>&1"):
        log("MAAS: not initialised")
        return
    machines = maas_json("machines read", check=False) or []
    log(f"MAAS: initialised, {len(machines)} machine(s)")
    for m in machines:
        log(f"  {m['hostname']}: {m['status_name']}")
    hosts = maas_json("vm-hosts read", check=False) or []
    for h in hosts:
        used, total = h["used"], h["total"]
        log(
            f"  VM host {h['name']}: {used['cores']}/{total['cores']} cores, "
            f"{used['memory']}/{total['memory']} MiB used"
        )
    report_ui_address()


def cmd_shell():
    if vm_ok(f"test -d {VM_TREE}"):
        os.execvp("lxc", ["lxc", "exec", VM, "--cwd", VM_TREE, "--", "bash", "-l"])
    os.execvp("lxc", ["lxc", "exec", VM, "--", "bash", "-l"])


def verify_foundation():
    """Assert exactly the composed machines are Ready with expected records."""
    machines = maas_json("machines read")
    expected = {n["hostname"] for n in expected_nodes()}
    actual = {m["hostname"] for m in machines}
    failures = []
    if actual != expected:
        failures.append(f"machine set mismatch: expected {sorted(expected)}, got {sorted(actual)}")
    for m in machines:
        if m["hostname"] not in expected:
            continue
        if m["status_name"] != "Ready":
            failures.append(f"{m['hostname']}: status {m['status_name']}, expected Ready")
        nics = m.get("interface_set", [])
        if not nics or not all(n.get("mac_address") for n in nics):
            failures.append(f"{m['hostname']}: missing interface or MAC record")
        subnets = {
            link["subnet"]["cidr"]
            for nic in nics
            for link in nic.get("links", [])
            if link.get("subnet")
        }
        if PXE["cidr"] not in subnets:
            failures.append(
                f"{m['hostname']}: no subnet record for {PXE['cidr']} (has {sorted(subnets)})"
            )
    if failures:
        for failure in failures:
            log(f"FAIL: {failure}")
        sys.exit(1)
    log(f"verify foundation: PASS ({len(expected)} machines Ready on {PXE['cidr']})")


def network_tester_run(extra_args):
    """Run the network-tester CLI inside the testbed VM against its MAAS."""
    key = vm_out(f"maas apikey --username {MAAS_CFG['admin_user']}")
    return vm_run(
        f"cd {VM_TREE} && uv run network-tester run {extra_args} "
        f"--maas-url {MAAS_URL} --maas-key {key}",
        check=False,
        capture=True,
    )


def verify_topology():
    """Dry-run against the testbed MAAS, plus the incomplete-config fault.

    The stage-3 testbed has only the management/PXE network, so the composed
    nodes classify as bmc-oam (their single fabric is a rack-controller
    fabric); the data VLAN that makes them data-role arrives in stage 5.
    """
    sync_tree()
    problems = []

    log("verify topology: clean dry-run --all")
    result = network_tester_run("--dry-run --all")
    output = result.stdout + result.stderr
    if result.returncode != 0:
        problems.append(f"clean dry-run exited {result.returncode}:\n{output}")
    else:
        for node in expected_nodes():
            pattern = rf"{node['hostname']} \(\w+\) rack=\S+ role=bmc-oam"
            if not re.search(pattern, output):
                problems.append(
                    f"dry-run output missing '{node['hostname']} ... role=bmc-oam':\n{output}"
                )
        for section in ("Would run:", "Would skip:"):
            if section not in output:
                problems.append(f"dry-run output missing '{section}' section")
        if "vlan-neighbor-validator" not in output:
            problems.append("dry-run output lists no vlan-neighbor checks")

    target = expected_nodes()[0]["hostname"]
    log(f"verify topology: incomplete-config fault on {target}")
    fault_incomplete_config([target])
    result = network_tester_run("--all")
    output = result.stdout + result.stderr
    if result.returncode == 0:
        problems.append("run --all succeeded despite incomplete config")
    elif "Pre-flight validation failed" not in output or target not in output:
        problems.append(f"pre-flight failure does not name {target}:\n{output}")

    log("verify topology: fault clear and re-check")
    clear_faults()
    result = network_tester_run("--dry-run --all")
    if result.returncode != 0:
        problems.append(
            f"dry-run after fault clear exited {result.returncode}:\n"
            f"{result.stdout + result.stderr}"
        )

    if problems:
        for problem in problems:
            log(f"FAIL: {problem}")
        sys.exit(1)
    log("verify topology: PASS (dry-run roles/checks, fault, and recovery)")


def vm_juju_models():
    """Names of network-test-* models on the testbed controller."""
    raw = vm_out("juju models --format json", check=False)
    if not raw:
        return []
    names = []
    for model in json.loads(raw).get("models", []):
        name = model.get("short-name") or model.get("name", "")
        name = name.split("/")[-1]
        if name.startswith("network-test-"):
            names.append(name)
    return names


def destroy_test_models():
    for name in vm_juju_models():
        log(f"destroying leftover model {name}")
        vm_run(f"juju destroy-model --no-prompt --force --timeout 10m {name}")


def wait_nodes_ready(timeout=900):
    expected = {n["hostname"] for n in expected_nodes()}

    def all_ready():
        machines = maas_json("machines read")
        states = {m["hostname"]: m["status_name"] for m in machines if m["hostname"] in expected}
        log(f"machine states: {states}")
        return len(states) == len(expected) and all(s == "Ready" for s in states.values())

    wait_for("nodes to return to Ready in MAAS", all_ready, timeout=timeout, interval=20)


def verify_skeleton():
    """End-to-end walking-skeleton gate: deploy, probe, collect, report, teardown.

    Runs the jubilant charm integration test against the testbed controller,
    then the full `network-tester run --all` pipeline on the MAAS cloud
    (auto-destroy path), then the --keep-model / status / --reuse-model path.
    """
    charm_name = ensure_charm_packed()
    sync_tree()
    ensure_juju()
    destroy_test_models()
    problems = []

    log("verify skeleton: jubilant charm integration test (LXD-backed model)")
    result = vm_run(
        f"cd {VM_TREE}/charm && NT_CHARM_PATH={VM_TREE}/charm/{charm_name} "
        "uv run --group integration pytest tests/integration -q",
        check=False,
        capture=True,
    )
    if result.returncode != 0:
        problems.append(f"jubilant test failed:\n{result.stdout}\n{result.stderr}")

    deploy_args = f"--charm charm/{charm_name} --cloud {MAAS_CLOUD} --wait-timeout 1800"
    node_count = len(expected_nodes())

    log("verify skeleton: full run with auto-destroy")
    result = network_tester_run(f"--all {deploy_args}")
    output = result.stdout + result.stderr
    if result.returncode != 0:
        problems.append(f"run --all exited {result.returncode}:\n{output}")
    else:
        for marker in (
            "triggering probe run",
            f"collecting results from {node_count} unit(s)",
            "All 0 checks passed.",
            "report written to ",
            "destroying model network-test-",
        ):
            if marker not in output:
                problems.append(f"run --all output missing '{marker}':\n{output}")
        match = re.search(r"report written to (\S+network-test-\S+\.json)", output)
        if match:
            report_raw = vm_out(f"cat {shlex.quote(match.group(1))}", check=False)
            try:
                report = json.loads(report_raw)
                if report.get("missing_nodes"):
                    problems.append(f"report has missing nodes: {report['missing_nodes']}")
                if report.get("schema_version") != "1":
                    problems.append("report schema_version is not '1'")
            except json.JSONDecodeError:
                problems.append(f"report file is not valid JSON: {match.group(1)}")
            text_report = match.group(1)[: -len(".json")] + ".txt"
            if not vm_ok(f"test -f {shlex.quote(text_report)}"):
                problems.append(f"text report missing: {text_report}")
        if vm_juju_models():
            problems.append(f"model not auto-destroyed: {vm_juju_models()}")
        else:
            wait_nodes_ready()

    if not problems:
        log("verify skeleton: keep-model run, status, and reuse-model re-trigger")
        result = network_tester_run(f"--all --keep-model {deploy_args}")
        output = result.stdout + result.stderr
        match = re.search(r"Model (network-test-\S+) kept", output)
        if result.returncode != 0 or not match:
            problems.append(f"keep-model run failed ({result.returncode}):\n{output}")
        else:
            model = match.group(1)
            status_out = vm_run(
                f"cd {VM_TREE} && uv run network-tester status", check=False, capture=True
            )
            status_text = status_out.stdout + status_out.stderr
            if status_out.returncode != 0 or model not in status_text:
                problems.append(f"status does not show kept model {model}:\n{status_text}")
            elif "probe complete" not in status_text:
                problems.append(f"status does not show probe completion:\n{status_text}")

            result = network_tester_run(f"--reuse-model {model} --wait-timeout 600")
            output = result.stdout + result.stderr
            if result.returncode != 0 or "All 0 checks passed." not in output:
                problems.append(f"reuse-model run failed ({result.returncode}):\n{output}")

            log(f"destroying kept model {model}")
            vm_run(f"juju destroy-model --no-prompt --force --timeout 15m {model}", check=False)
            wait_nodes_ready()

    if problems:
        for problem in problems:
            log(f"FAIL: {problem}")
        sys.exit(1)
    log("verify skeleton: PASS (jubilant test, full pipeline, keep/status/reuse)")


VERIFY_STAGES = {
    "foundation": verify_foundation,
    "topology": verify_topology,
    "skeleton": verify_skeleton,
}


# --- faults -------------------------------------------------------------------


def _addressed_links(interface):
    """Links that configure addressing. MAAS represents a link-less interface
    with a mode=link_up entry that still references the subnet; it assigns no
    address and does not count as configuration."""
    return [
        ln for ln in interface.get("links", []) if ln.get("subnet") and ln.get("mode") != "link_up"
    ]


def fault_incomplete_config(args):
    """Remove the subnet link from a node's boot interface via the MAAS API."""
    if len(args) != 1:
        fatal("usage: nt-testbed fault incomplete-config <hostname>")
    hostname = args[0]
    machines = maas_json("machines read")
    machine = next((m for m in machines if m["hostname"] == hostname), None)
    if machine is None:
        fatal(f"no machine named {hostname}; have: {sorted(m['hostname'] for m in machines)}")
    boot_id = (machine.get("boot_interface") or {}).get("id")
    interface = next(i for i in machine["interface_set"] if i["id"] == boot_id)
    removed = 0
    for link in _addressed_links(interface):
        maas_json(
            f"interface unlink-subnet {machine['system_id']} {interface['id']} id={link['id']}"
        )
        removed += 1
    if removed:
        log(
            f"fault injected: removed {removed} subnet link(s) from {hostname} {interface['name']}"
        )
    else:
        log(f"{hostname} {interface['name']} already has no addressed subnet links")


def clear_incomplete_config():
    """Restore subnet links on any interface that lost them (from topology.yaml)."""
    subnets = maas_json("subnets read")
    pxe = next((s for s in subnets if s["cidr"] == PXE["cidr"]), None)
    if pxe is None:
        fatal(f"PXE subnet {PXE['cidr']} not found in MAAS")
    for machine in maas_json("machines read"):
        for interface in machine["interface_set"]:
            if not interface.get("vlan"):
                continue
            if _addressed_links(interface):
                continue
            maas_json(
                f"interface link-subnet {machine['system_id']} "
                f"{interface['id']} mode=AUTO subnet={pxe['id']}"
            )
            log(
                f"fault cleared: restored subnet link on {machine['hostname']} {interface['name']}"
            )


FAULTS = {"incomplete-config": fault_incomplete_config}
CLEAR_FUNCS = [clear_incomplete_config]


def clear_faults():
    for clear in CLEAR_FUNCS:
        clear()


def cmd_fault(name, args):
    if name == "clear":
        clear_faults()
        log("fault state restored from topology.yaml")
        return
    if name not in FAULTS:
        fatal(f"unknown fault '{name}'; available: {', '.join(sorted(FAULTS))}")
    FAULTS[name](args)


def main():
    parser = argparse.ArgumentParser(prog="nt-testbed", description=__doc__)
    sub = parser.add_subparsers(dest="command", required=True)
    sub.add_parser("up", help="create/refresh the whole testbed (idempotent)")
    sub.add_parser("down", help="delete the testbed VM and check for leftovers")
    sub.add_parser("status", help="show testbed VM, MAAS, and machine state")
    sub.add_parser("shell", help="open a shell inside the testbed VM")
    verify = sub.add_parser("verify", help="run a stage verification")
    verify.add_argument("stage", choices=sorted(VERIFY_STAGES))
    fault = sub.add_parser("fault", help="inject or clear a testbed fault")
    fault.add_argument("name")
    fault.add_argument("args", nargs="*")
    args = parser.parse_args()

    if args.command == "up":
        cmd_up()
    elif args.command == "down":
        cmd_down()
    elif args.command == "status":
        cmd_status()
    elif args.command == "shell":
        cmd_shell()
    elif args.command == "verify":
        VERIFY_STAGES[args.stage]()
    elif args.command == "fault":
        cmd_fault(args.name, args.args)


if __name__ == "__main__":
    main()
