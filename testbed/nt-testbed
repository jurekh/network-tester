def _rack1_representative_host():
    """Hostname of rack 1's deterministic representative (lowest data system_id)."""
    rack1_data = {
        n["hostname"]
        for n in expected_nodes()
        if n.get("rack") == "rack-1" and n.get("role") == "data"
    }
    machines = maas_json("machines read")
    candidates = sorted(
        (m["system_id"], m["hostname"]) for m in machines if m["hostname"] in rack1_data
    )
    if not candidates:
        fatal("no rack-1 data nodes found for rep-wrong-vlan")
    return candidates[0][1]


REP_WRONG_TAG = 777


def fault_rep_wrong_vlan(args):
    """Retag the rack-1 representative's data bond onto a stray VLAN.

    This isolates the representative on the data fabric, so its vlan-validator
    records a definitive missing-l2-neighbor (a phase-1 failure on a rep),
    which the report-generator uses to gate that rack's outbound cross-rack
    findings to inconclusive.
    """
    if RACK2 is None:
        fatal("rep-wrong-vlan requires the multirack topology")
    rep_host = _rack1_representative_host()
    _pause_reconciler()
    vm_run(f"ovs-vsctl set port {ovs_bond_name(rep_host)} tag={REP_WRONG_TAG}")
    log(f"fault injected: rack-1 representative {rep_host} data bond retagged to {REP_WRONG_TAG}")


def clear_rep_wrong_vlan():
    if RACK2 is None:
        return
    data_tag = VLANS["data"]["tag"]
    for node in expected_nodes():
        if node.get("rack") == "rack-1" and node_bond(node):
            name = ovs_bond_name(node["hostname"])
            vm_run(f"ovs-vsctl --if-exists set port {name} tag={data_tag}", check=False)
    vm_run(f"rm -f {BOND_PAUSE_FLAG}", check=False)


