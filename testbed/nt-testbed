def log(msg):
    print(f"[{time.strftime('%H:%M:%S')}] {msg}", flush=True)


def fatal(msg):
    log(f"FATAL: {msg}")
    sys.exit(1)


def host_run(args, check=True, capture=False, cwd=None):
    result = subprocess.run(args, check=False, text=True, capture_output=capture, cwd=cwd)
    if check and result.returncode != 0:
        fatal(
            f"command failed ({result.returncode}): {shlex.join(args)}\n"
            f"{(result.stderr or '') if capture else ''}"
        )
    return result


def vm_run(script, check=True, capture=False):
    """Run a bash script inside the testbed VM."""
    return host_run(["lxc", "exec", VM, "--", "bash", "-c", script], check=check, capture=capture)


def vm_out(script, check=True):
    return vm_run(script, check=check, capture=True).stdout.strip()


def vm_ok(script):
    return vm_run(script, check=False, capture=True).returncode == 0


def maas_json(cmd, check=True):
    """Run a maas CLI command inside the VM and parse its JSON output."""
    result = vm_run(f"maas {MAAS_CFG['admin_user']} {cmd}", check=check, capture=True)
    if result.returncode != 0:
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        if check:
            fatal(f"maas {cmd}: expected JSON, got:\n{result.stdout[:2000]}")
        return None


def wait_for(desc, predicate, timeout, interval=10):
    log(f"waiting for {desc} (timeout {timeout}s)")
    deadline = time.time() + timeout
    while time.time() < deadline:
        result = predicate()
        if result:
            return result
        time.sleep(interval)
    fatal(f"timed out waiting for {desc}")


def restart_maas():
    """Restart MAAS and wait for its API to come back."""
    log("restarting MAAS")
    vm_run("snap restart maas")
    wait_for(
        "MAAS API",
        lambda: vm_ok(f"curl -fsS {MAAS_URL}/api/2.0/version/ >/dev/null"),
        timeout=300,
        interval=10,
    )


def wait_or_restart(desc, predicate, timeout=180, interval=15):
    """Wait for predicate; if it stalls, restart MAAS once and wait again.

    MAAS rackd intermittently drops the OVS bridge interfaces (br-rack1,
    br-rack1.<tag>, br-rack2) from the controller's reported interface set, so
    interface-discovery waits can stall even though the bridges are up in the
    VM. A MAAS restart forces a fresh rackd interface scan that restores them.
    """
    deadline = time.time() + timeout
    while time.time() < deadline:
        if predicate():
            return
        time.sleep(interval)
    log(f"{desc} stalled; restarting MAAS to force a rack-controller interface rescan")
    restart_maas()
    wait_for(desc, predicate, timeout=timeout, interval=interval)


def expected_nodes():
    nodes = []
    for rack_name, rack in CONFIG["racks"].items():
        for node in rack["nodes"]:
            node.setdefault("rack", rack_name)
            nodes.append(node)
    return nodes


def node_net(node):
    """Bridge / pxe / vlans for the rack a node belongs to."""
    return rack_net(node.get("rack", "rack-1"))


def nic_cidr(node, nic):
    """The subnet a configured NIC belongs to (the rack PXE when untagged)."""
    net = node_net(node)
    return net["vlans"][nic["vlan"]]["cidr"] if nic.get("vlan") else net["pxe"]["cidr"]


def node_bond(node):
    """The bond descriptor for a node, or None when it has no bond."""
    return node.get("bond")


def bond_member_devices(node):
    """Guest NIC device names that are bond members, in order.

    Members are added after the configured NICs, so for a data node with one
    boot NIC (eth0) and a two-member bond the members are eth1 and eth2.
    """
    bond = node_bond(node)
    if not bond:
        return []
    base = len(node.get("nics", []))
    return [f"eth{base + j}" for j in range(bond["members"])]


def expected_physical_nics(node):
    """Total physical NICs MAAS should record for a node (NICs + bond members)."""
    return len(node.get("nics", [])) + len(bond_member_devices(node))


def ovs_bond_name(host):
    """Host-side OVS bond port name aggregating a node's member NICs."""
    return f"ob-{host}"


def swap_extra_names(host):
    """Names for the bond-swap fault's wrong-switch bond and its pad netdevs.

    The pad interfaces are real netdevs, so their names must fit the 15-char
    kernel limit; derive a short per-node suffix from the hostname digits.
    """
    digits = re.findall(r"\d+", host)
    suffix = digits[-1] if digits else "0"
    return {"wrong": f"obw{suffix}", "pad_a": f"obpa{suffix}", "pad_b": f"obpb{suffix}"}


def inner_nic_devices(host):
    """NIC devices of an inner LXD instance: name -> device dict with hwaddr."""
    raw = vm_out(f"lxc config show {host} --expanded", check=False)
    if not raw:
        return {}
    doc = yaml.safe_load(raw)
    nics = {n: d for n, d in (doc.get("devices") or {}).items() if d.get("type") == "nic"}
    volatile = doc.get("config") or {}
    for name, device in nics.items():
        device["hwaddr"] = (volatile.get(f"volatile.{name}.hwaddr") or "").lower()
    return nics


# --- up steps ----------------------------------------------------------------


def vm_exists():
    result = host_run(["lxc", "list", VM, "--format", "json"], capture=True)
    return any(i["name"] == VM for i in json.loads(result.stdout))


# Set when `up` (re)starts a pre-existing VM rather than launching a fresh one.
# A restart recreates the bridge VLAN subinterfaces, leaving MAAS's dhcpd bound
# to the old ones until it is restarted (see ensure_dhcp_rebind).
_STATE = {"vm_restarted": False}


def ensure_vm():
    if vm_exists():
        log(f"VM {VM} already exists")
        _STATE["vm_restarted"] = True
        host_run(["lxc", "start", VM], check=False, capture=True)
    else:
        cfg = CONFIG["vm"]
        log(f"launching VM {VM} ({cfg['cpu']} CPU, {cfg['memory']}, {cfg['disk']} disk)")
        host_run(
            [
                "lxc",
                "launch",
                cfg["image"],
                VM,
                "--vm",
                "-c",
                f"limits.cpu={cfg['cpu']}",
                "-c",
                f"limits.memory={cfg['memory']}",
                "-d",
                f"root,size={cfg['disk']}",
            ]
        )
    wait_for(
        "VM agent",
        lambda: (
            host_run(["lxc", "exec", VM, "--", "true"], check=False, capture=True).returncode == 0
        ),
        timeout=300,
        interval=5,
    )
    vm_run("cloud-init status --wait >/dev/null || true")
    if not vm_ok("test -e /dev/kvm"):
        fatal(
            "nested KVM is not available inside the testbed VM (/dev/kvm missing); "
            "the host must support nested virtualization"
        )
    log("VM is up with nested KVM available")


def ensure_packages():
    maas_channel = MAAS_CFG.get("channel")
    for snap, channel, args in (
        ("maas-test-db", maas_channel, ""),
        ("maas", maas_channel, ""),
        ("lxd", None, ""),
        ("astral-uv", None, "--classic"),
    ):
        if vm_ok(f"snap list {snap} >/dev/null 2>&1"):
            if channel:
                tracking = vm_out(f"snap list {snap} | awk 'NR==2 {{print $4}}'")
                if tracking != channel:
                    log(
                        f"note: snap {snap} tracks {tracking} but topology.yaml wants "
                        f"{channel}; run `nt-testbed down && nt-testbed up` to rebuild"
                    )
            continue
        flag = f" --channel={channel}" if channel else ""
        log(f"installing snap {snap}{flag.replace('=', ' ')}")
        vm_run(f"snap install {snap}{flag} {args}")
    if not vm_ok("dpkg -s openvswitch-switch >/dev/null 2>&1"):
        log("installing openvswitch-switch")
        vm_run("apt-get update -q && apt-get install -qy openvswitch-switch")


def pin_bridge_mac(bridge, mac):
    """Pin an OVS bridge MAC so it never derives from (and flaps with) its
    member ports.

    An OVS bridge with no other-config:hwaddr takes its MAC from a member port,
    so when node taps churn the bridge (compose, commission, power cycles) the
    MAC transiently flaps. The rack controller's interface scan
    (get_all_interfaces_definition) drops any interface without a MAC, so a
    flapping bridge MAC makes the rack omit the bridge from its report and the
    region deletes it. That single drop cascades: pod compose falls back to
    macvlan (nodes can't reach DHCP), the LXD BMC power query fails ("No rack
    controllers can access the BMC"), and VLAN-interface discovery stalls. A
    fixed MAC keeps the bridge continuously present.
    """
    vm_run(f"ovs-vsctl set bridge {bridge} other-config:hwaddr={mac}")
    vm_run(f"ip link set {bridge} address {mac}")


def ensure_bridge():
    cidr, gateway = PXE["cidr"], PXE["gateway"]
    pxe_bridge, ovs_bridge = PXE["bridge"], PXE["ovs_bridge"]
    # The PXE/BMC/compose segment is a Linux bridge: MAAS's resource scanner
    # does not report OVS datapath bridges as interfaces, so a pod composed
    # against an OVS bridge falls back to macvlan (the node then cannot reach
    # the testbed VM's DHCP, which is the macvlan parent) and the LXD BMC power
    # query fails. A Linux bridge is reported reliably. Its MAC is pinned so it
    # never changes with port membership.
    if not vm_ok(f"ip link show {pxe_bridge} >/dev/null 2>&1"):
        vm_run(f"ip link add {pxe_bridge} type bridge")
    vm_run(f"ip link set {pxe_bridge} address 02:00:00:aa:00:01")
    vm_run(
        f"ip addr replace {gateway}/{cidr.split('/')[1]} dev {pxe_bridge} && "
        f"ip link set {pxe_bridge} up"
    )
    # The OVS bridge carries the tagged mgmt/oam/data VLANs and the LACP bonds.
    # It has no IP; node mgmt/bond NICs move here (bridged) after commissioning.
    vm_run(f"ovs-vsctl --may-exist add-br {ovs_bridge}")
    pin_bridge_mac(ovs_bridge, "02:00:00:aa:01:01")
    vm_run(f"ip link set {ovs_bridge} up")
    # NAT so composed nodes can reach the internet via the testbed VM
    # (not needed for commissioning, but required when charms apt-install).
    vm_run("sysctl -qw net.ipv4.ip_forward=1")
    vm_run(
        f"iptables -t nat -C POSTROUTING -s {cidr} ! -d {cidr} -j MASQUERADE 2>/dev/null"
        f" || iptables -t nat -A POSTROUTING -s {cidr} ! -d {cidr} -j MASQUERADE"
    )
    log(f"PXE Linux bridge {pxe_bridge} up at {gateway}; OVS bridge {ovs_bridge} up; NAT {cidr}")


def ensure_maas():
    if not vm_ok("maas status >/dev/null 2>&1"):
        log("initialising MAAS region+rack with maas-test-db")
        vm_run(f"maas init region+rack --database-uri maas-test-db:/// --maas-url {MAAS_URL}")
    wait_for(
        "MAAS API",
        lambda: vm_ok(f"curl -fsS {MAAS_URL}/api/2.0/version/ >/dev/null"),
        timeout=300,
        interval=10,
    )
    user = MAAS_CFG["admin_user"]
    if not vm_ok(f"maas apikey --username {user} >/dev/null 2>&1"):
        log(f"creating MAAS admin user {user}")
        vm_run(
            f"maas createadmin --username {user} "
            f"--password {MAAS_CFG['admin_password']} "
            f"--email {MAAS_CFG['admin_email']}"
        )
    if not vm_ok(f"maas list | grep -q '^{user} '"):
        vm_run(f'maas login {user} {MAAS_URL} "$(maas apikey --username {user})"')
    # MAAS bind9 serves DNS to the PXE segment: the Juju controller and the
    # deployed nodes resolve through it. Pin an explicit upstream forwarder and
    # disable DNSSEC so external names (apt mirrors) resolve. Auto-recursion can
    # SERVFAIL or time out in the nested testbed, which silently hangs apt during
    # Juju bootstrap and node deploys (the failure looks like a stuck bootstrap).
    vm_run(f"maas {user} maas set-config name=upstream_dns value='1.1.1.1 8.8.8.8'", check=False)
    vm_run(f"maas {user} maas set-config name=dnssec_validation value=no", check=False)
    log("MAAS is initialised and the admin profile is logged in")


def ensure_dhcp_rebind():
    """After a VM restart, restart MAAS so dhcpd rebinds to the VLAN subinterfaces.

    Restarting the VM recreates br-rack1.<tag>; the persisted dhcpd stays bound
    to the old interface instances and silently stops answering PXE DHCP, so
    node deploys fall through to the stale on-disk image and never reinstall.
    Restarting MAAS rebinds dhcpd. Only needed on a restart of an already-built
    testbed, so it is skipped on a fresh bring-up.
    """
    if not _STATE["vm_restarted"]:
        return
    log("VM was restarted; restarting MAAS to rebind dhcpd to the VLAN subinterfaces")
    vm_run("snap restart maas")
    wait_for(
        "MAAS API",
        lambda: vm_ok(f"curl -fsS {MAAS_URL}/api/2.0/version/ >/dev/null"),
        timeout=300,
        interval=10,
    )


def ensure_subnet_dhcp():
    rack_controllers = wait_for(
        "rack controller registration",
        lambda: maas_json("rack-controllers read"),
        timeout=600,
        interval=15,
    )
    rack_id = rack_controllers[0]["system_id"]

    cidr = PXE["cidr"]
    subnet = wait_for(
        f"subnet {cidr} discovery",
        lambda: next((s for s in maas_json("subnets read") if s["cidr"] == cidr), None),
        timeout=300,
        interval=10,
    )
    if subnet.get("gateway_ip") != PXE["gateway"]:
        maas_json(f"subnet update {subnet['id']} gateway_ip={PXE['gateway']}")

    ranges = maas_json("ipranges read")
    start = PXE["dhcp_range"]["start"]
    end = PXE["dhcp_range"]["end"]
    if not any(r["start_ip"] == start for r in ranges):
        log(f"creating dynamic DHCP range {start}-{end}")
        maas_json(f"ipranges create type=dynamic start_ip={start} end_ip={end}")

    vlan = subnet["vlan"]
    if not vlan["dhcp_on"]:
        log(f"enabling MAAS DHCP on fabric {vlan['fabric']} vid {vlan['vid']}")
        maas_json(
            f"vlan update {vlan['fabric_id']} {vlan['vid']} dhcp_on=true primary_rack={rack_id}"
        )
    log("PXE subnet and DHCP configured")


def ensure_images():
    resources = maas_json("boot-resources read")
    if not any(r["name"].startswith("ubuntu/") and r["type"] == "Synced" for r in resources):
        log("starting boot image import (this can take a while)")
        maas_json("boot-resources import", check=False)
        time.sleep(15)
    wait_for(
        "boot image import to finish",
        lambda: (
            maas_json("boot-resources is-importing") is False
            and any(
                r["name"].startswith("ubuntu/") and r["type"] == "Synced"
                for r in maas_json("boot-resources read")
            )
        ),
        timeout=3600,
        interval=30,
    )

    def rack_boot_proxy_ready():
        # Rack controllers do not sync boot images; they proxy and cache them
        # from the region on demand via the maas-agent HTTP boot proxy on port
        # 5248 (only region controllers replicate images, in HA/multi-region
        # setups). The meaningful readiness signal is that proxy actually
        # serving a bootloader: a 200 for bootx64.efi (the URL nodes fetch over
        # PXE) means the agent is healthy and can fetch/cache from the region,
        # which is what lets nodes boot. An unhealthy agent returns 502 here
        # even after the region import is complete (the list-boot-images API is
        # deprecated and hardcodes status: synced, so it cannot detect this).
        return vm_ok("curl -fsS -o /dev/null http://localhost:5248/images/bootx64.efi")

    wait_for(
        "rack controller boot proxy to serve bootloaders",
        rack_boot_proxy_ready,
        timeout=900,
        interval=20,
    )
    log("rack controller boot proxy serving bootloaders (proxied/cached from the region)")


def ensure_inner_lxd():
    vm_run("lxd waitready --timeout 120")
    if not vm_ok("lxc storage show default >/dev/null 2>&1"):
        vm_run("lxc storage create default dir")
    if not vm_ok("lxc profile device get default root pool >/dev/null 2>&1"):
        vm_run("lxc profile device add default root disk path=/ pool=default")
    bridge = PXE["bridge"]
    parent = vm_run(
        "lxc profile device get default eth0 parent", check=False, capture=True
    ).stdout.strip()
    if parent != bridge:
        vm_run("lxc profile device remove default eth0 2>/dev/null || true")
        vm_run(f"lxc profile device add default eth0 nic nictype=bridged parent={bridge}")
    address = vm_out("lxc config get core.https_address")
    if address != f"{PXE['gateway']}:8443":
        vm_run(f"lxc config set core.https_address {PXE['gateway']}:8443")
    log("inner LXD initialised (default profile on the PXE bridge)")


def ensure_vm_host():
    name = MAAS_CFG["vm_host_name"]
    hosts = maas_json("vm-hosts read")
    if any(h["name"] == name for h in hosts):
        log(f"VM host {name} already registered")
        return
    token = vm_out("lxc config trust add --name maas --quiet")
    token = token.splitlines()[-1].strip()
    log(f"registering inner LXD as MAAS VM host {name}")
    maas_json(
        f"vm-hosts create type=lxd power_address={PXE['gateway']}:8443 "
        f"project=default name={name} password={token}"
    )


def _compose_machine(host_id, node):
    """Compose one node, recovering from MAAS dropping the host bridges.

    Composing a VM creates a tap on the bridge, which makes rackd rescan, and
    rackd intermittently drops the OVS bridges from its interface report during
    that rescan. The next compose then fails with "No host network to attach VM
    interfaces to". A MAAS restart restores the bridge report, so restart and
    retry on that error (capped) rather than aborting the whole up.
    """
    host = node["hostname"]
    cmd = (
        f"vm-host compose {host_id} cores={node['cpu']} "
        f"memory={node['memory_mib']} hostname={host} "
        f"storage=main:{node['disk_gib']}"
    )
    restarts = 0
    cleaned = False
    while True:
        result = vm_run(f"maas {MAAS_CFG['admin_user']} {cmd}", check=False, capture=True)
        if result.returncode == 0:
            return
        out = result.stdout + result.stderr
        if "already exists" in out and not cleaned:
            # Orphan LXD instance from an interrupted compose (no MAAS record);
            # remove it and retry.
            cleaned = True
            vm_run(f"lxc delete --force {host}", check=False)
            continue
        transient = "No host network" in out or "does not match the specified networks" in out
        if transient and restarts < 5:
            restarts += 1
            restart_maas()
            continue
        fatal(f"compose {host} failed ({result.returncode}):\n{out}")


def _wait_pod_networks():
    """Wait for the rack controller to report the PXE compose bridge to MAAS.

    Pods compose against the Linux PXE bridge (the inner LXD default profile).
    MAAS must see that bridge in the host controller's interfaces or compose
    falls back to macvlan ("No host network to attach VM interfaces to" /
    macvlan NICs that cannot reach DHCP). The Linux bridge is reported
    reliably, but just after a MAAS restart the rackd rescan may not have run
    yet; wait for it, restarting MAAS once if it has not appeared.
    """
    bridge = PXE["bridge"]

    def discovered():
        controllers = maas_json("rack-controllers read") or []
        names = {i["name"] for rc in controllers for i in rc["interface_set"]}
        return bridge in names

    wait_or_restart(
        "rack controller to report the PXE bridge", discovered, timeout=90, interval=10
    )


def ensure_machines():
    """Compose every expected node, then wait for them all to reach Ready.

    Composes are fired for all not-yet-existing nodes and MAAS commissions them
    in parallel; the single wait at the end gates `up`. Composing on the Linux
    PXE bridge (which MAAS reports reliably) and pinning the OVS bridge MACs
    removed the rackd bridge-drop that earlier forced one-node-at-a-time
    commissioning, so per-node serialization and its restart/recompose recovery
    are no longer needed.
    """
    host_id = next(
        h["id"] for h in maas_json("vm-hosts read") if h["name"] == MAAS_CFG["vm_host_name"]
    )
    existing = {m["hostname"] for m in maas_json("machines read")}
    to_compose = [n for n in expected_nodes() if n["hostname"] not in existing]
    if to_compose:
        _wait_pod_networks()
        for node in to_compose:
            log(
                f"composing {node['hostname']} "
                f"({node['cpu']} CPU, {node['memory_mib']} MiB, {node['disk_gib']} GiB)"
            )
            _compose_machine(host_id, node)
        wait_nodes_ready(timeout=1800)
    log("all composed machines are Ready")


def _ensure_forward(cidr):
    """Allow the testbed VM to route this VLAN to PXE (Juju controller) and out.

    The Juju controller stays on the untagged PXE segment and reaches node
    agents by L3 routing through the testbed VM, so its MAC never appears on
    the isolated VLANs the vlan-neighbor-validator probes. LXD sets the
    FORWARD policy to DROP, so the routes need explicit ACCEPT rules.
    """
    for spec in (f"-s {cidr}", f"-d {cidr}"):
        vm_run(
            f"iptables -C FORWARD {spec} -j ACCEPT 2>/dev/null"
            f" || iptables -A FORWARD {spec} -j ACCEPT"
        )


def vlan_device(tag):
    """Kernel name of the Linux 802.1q subinterface for a tag on the bridge."""
    return f"{PXE['ovs_bridge']}.{tag}"


def management_vlans():
    return [(name, vlan) for name, vlan in VLANS.items() if vlan.get("management")]


def _rc_vlan_iface(rack_id, dev):
    rc = next(c for c in maas_json("rack-controllers read") if c["system_id"] == rack_id)
    return next((i for i in rc["interface_set"] if i["name"] == dev), None)


def ensure_vlan_networks():
    """Linux 802.1q VLAN subinterfaces plus MAAS subnet/DHCP for management VLANs.

    MAAS does not model OVS internal ports (its scanner reports only PCI cards
    and its controller discovery cannot see OVS-internal VLAN tags), so the
    rack-controller's presence on each management VLAN is a Linux 802.1q
    subinterface (br-rack1.<tag>) on the bridge LOCAL port, which is an OVS
    trunk. MAAS discovers these natively as vid-tagged VLAN interfaces and
    serves DHCP on them; OVS bridges their frames to the nodes' access-tagged
    ports. MAAS places each discovered subinterface on a vid-tagged VLAN of
    the bridge's own fabric (fabric-0), so the subnet/range/DHCP bind to that
    discovered VLAN rather than a separate pre-created fabric. The data VLAN
    has no controller presence (ensure_data_segments models it as its own
    data fabric). Run before the inner LXD exists so the controller refresh
    sees a stable interface set.
    """
    mgmt = management_vlans()
    if not mgmt:
        return
    bridge = PXE["ovs_bridge"]
    for name, vlan in mgmt:
        tag, cidr, gateway = vlan["tag"], vlan["cidr"], vlan["gateway"]
        dev = vlan_device(tag)
        prefix = cidr.split("/")[1]
        vm_run(
            f"ip link show {dev} >/dev/null 2>&1 || "
            f"ip link add link {bridge} name {dev} type vlan id {tag}"
        )
        vm_run(f"ip addr replace {gateway}/{prefix} dev {dev} && ip link set {dev} up")
        vm_run(
            f"iptables -t nat -C POSTROUTING -s {cidr} ! -d {cidr} -j MASQUERADE 2>/dev/null"
            f" || iptables -t nat -A POSTROUTING -s {cidr} ! -d {cidr} -j MASQUERADE"
        )
        _ensure_forward(cidr)

    rack_id = maas_json("rack-controllers read")[0]["system_id"]

    # MAAS models an 802.1q subinterface on br-rack1 as a vid-tagged VLAN on
    # the bridge's own fabric (fabric-0); it does not place it on a separate
    # pre-created fabric, and a vlan-type interface cannot be reassigned to
    # another fabric afterwards. So wait for the rack controller to discover
    # each subinterface, then bind that discovered VLAN's subnet, dynamic
    # range, and DHCP to it (subnet follows interface). Doing this before
    # discovery races the controller refresh: the subnet lands on a stale
    # fabric and DHCP cannot be enabled on the interface's real VLAN.
    def discovered():
        for name, vlan in mgmt:
            iface = _rc_vlan_iface(rack_id, vlan_device(vlan["tag"]))
            if iface is None or (iface.get("vlan") or {}).get("vid") != vlan["tag"]:
                return False
        return True

    wait_or_restart(
        "rack-controller VLAN interface discovery", discovered, timeout=180, interval=15
    )

    ranges = maas_json("ipranges read")
    for name, vlan in mgmt:
        tag, cidr, gateway = vlan["tag"], vlan["cidr"], vlan["gateway"]
        iface = _rc_vlan_iface(rack_id, vlan_device(tag))
        mvlan = iface["vlan"]
        subnet = next((s for s in maas_json("subnets read") if s["cidr"] == cidr), None)
        if subnet is None:
            log(f"creating MAAS subnet {cidr} for VLAN {name}")
            maas_json(f"subnets create cidr={cidr} vlan={mvlan['id']} gateway_ip={gateway}")
        elif subnet["vlan"]["id"] != mvlan["id"]:
            maas_json(f"subnet update {subnet['id']} vlan={mvlan['id']} gateway_ip={gateway}")
        elif subnet.get("gateway_ip") != gateway:
            maas_json(f"subnet update {subnet['id']} gateway_ip={gateway}")
        rng = vlan.get("dhcp_range")
        if rng and not any(r["start_ip"] == rng["start"] for r in ranges):
            log(f"creating dynamic DHCP range for VLAN {name}: {rng['start']}-{rng['end']}")
            maas_json(f"ipranges create type=dynamic start_ip={rng['start']} end_ip={rng['end']}")
        if not mvlan["dhcp_on"]:
            log(f"enabling MAAS DHCP on VLAN {name} (fabric {mvlan['fabric_id']} vid {tag})")
            maas_json(
                f"vlan update {mvlan['fabric_id']} {mvlan['vid']} "
                f"dhcp_on=true primary_rack={rack_id}"
            )
    log("management VLAN networks configured (802.1q subinterfaces, subnets, DHCP)")


def _data_vlans():
    """(rack, vlan_name, vlan_cfg) for every controller-less data VLAN."""
    out = [("rack-1", n, v) for n, v in VLANS.items() if not v.get("management")]
    if RACK2 is not None:
        out += [("rack-2", n, v) for n, v in RACK2["vlans"].items() if not v.get("management")]
    return out


def ensure_data_segments():
    """Model controller-less data VLANs in MAAS, with the FRR ToR as gateway.

    Each data subnet's gateway_ip is the rack's FRR router (stage 7) so the
    topology JSON carries it and cross-rack traffic routes by BGP. Same-rack
    L2 neighbor checks are unaffected; the vlan-validator treats the gateway
    as infrastructure.
    """
    for rack, name, vlan in _data_vlans():
        fabric_name = vlan["fabric"]
        fabric = next((f for f in maas_json("fabrics read") if f["name"] == fabric_name), None)
        if fabric is None:
            log(f"creating MAAS fabric {fabric_name}")
            fabric = maas_json(f"fabrics create name={fabric_name}")
        mvlan = next(
            (v for v in maas_json(f"vlans read {fabric['id']}") if v["vid"] == vlan["tag"]), None
        )
        if mvlan is None:
            mvlan = maas_json(f"vlans create {fabric['id']} vid={vlan['tag']} name={name}")
        gw = vlan.get("gateway")
        subnet = next((s for s in maas_json("subnets read") if s["cidr"] == vlan["cidr"]), None)
        if subnet is None:
            log(f"creating MAAS subnet {vlan['cidr']} on fabric {fabric_name}")
            args = f"cidr={vlan['cidr']} vlan={mvlan['id']}"
            if gw:
                args += f" gateway_ip={gw}"
            maas_json(f"subnets create {args}")
        else:
            if subnet["vlan"]["id"] != mvlan["id"]:
                maas_json(f"subnet update {subnet['id']} vlan={mvlan['id']}")
            if gw and subnet.get("gateway_ip") != gw:
                maas_json(f"subnet update {subnet['id']} gateway_ip={gw}")


def ensure_data_routes():
    """MAAS static routes so each rack's data subnet reaches the other's via
    its own FRR ToR.

    The data nodes default-route through their PXE/mgmt NIC (so MAAS and the
    Juju controller stay reachable independent of the data fabric), so a data
    subnet's FRR gateway_ip alone does not give a node a route to the remote
    rack's data subnet: cross-rack data traffic would follow the default route
    off the testbed instead of via BGP. These static routes are rendered into
    the deployed nodes' netplan as a route to the remote data subnet through
    the local FRR gateway.
    """
    if not (RACK2 and ROUTERS):
        return
    subnets = {s["cidr"]: s["id"] for s in maas_json("subnets read")}
    r1_cidr, r2_cidr = VLANS["data"]["cidr"], RACK2["vlans"]["data"]["cidr"]
    pairs = [
        (r1_cidr, r2_cidr, ROUTERS["rack-1"]["data_ip"]),
        (r2_cidr, r1_cidr, ROUTERS["rack-2"]["data_ip"]),
    ]
    existing = maas_json("static-routes read") or []
    for src_cidr, dst_cidr, gw in pairs:
        src_id, dst_id = subnets.get(src_cidr), subnets.get(dst_cidr)
        if src_id is None or dst_id is None:
            fatal(f"data route {src_cidr} -> {dst_cidr}: subnet not found in MAAS")
        if any(r["source"]["id"] == src_id and r["destination"]["id"] == dst_id for r in existing):
            continue
        log(f"adding cross-rack data route {src_cidr} -> {dst_cidr} via {gw}")
        maas_json(f"static-routes create source={src_id} destination={dst_id} gateway_ip={gw}")
    log("cross-rack data routes configured")


# --- rack 2 (stage 7) --------------------------------------------------------


def _ctrl_ip(gateway):
    """Rack-2 controller's address on a segment: the gateway's .2 host."""
    return gateway.rsplit(".", 1)[0] + ".2"


def ensure_rack2_bridge():
    """OVS bridge br-rack2 for rack 2; the testbed VM owns the rack-2 gateway.

    The testbed VM is the single router for both racks (management/PXE): it
    owns the rack-2 PXE gateway on br-rack2, NATs rack-2 traffic out, and
    forwards between racks so MAAS and the Juju controller reach rack-2 over
    routed management, independent of the data fabric.

    The PXE segment is an OVS access VLAN (pxe_access_vlan), not the bridge's
    untagged native VLAN: an untagged OVS port is a trunk that also carries the
    tagged data VLAN 100, so the data VLAN's broadcast ARP would leak onto the
    boot NICs and the vlan-neighbor-validator (which strips the 802.1q tag)
    would report data peers as unexpected neighbors on the PXE interface. The
    bridge's own (LOCAL) port carries the gateway on the access VLAN; node and
    controller PXE NICs join it via their LXD `vlan` setting. Keeping the
    gateway on br-rack2 (an OVS bridge MAAS's scanner ignores) also means the
    region controller gains no interface on the rack-2 PXE subnet.
    """
    if RACK2 is None:
        return
    bridge = RACK2["bridge"]
    vm_run(f"ovs-vsctl --may-exist add-br {bridge}")
    pin_bridge_mac(bridge, "02:00:00:aa:02:01")
    pxe = RACK2["pxe"]
    prefix = pxe["cidr"].split("/")[1]
    vm_run(f"ip addr replace {pxe['gateway']}/{prefix} dev {bridge} && ip link set {bridge} up")
    # Place the gateway's LOCAL port on the PXE access VLAN so it shares the
    # nodes' isolated segment (the nodes and controller tag their ports to the
    # same VLAN); the data VLAN 100 stays on the bond ports only.
    vm_run(f"ovs-vsctl set port {bridge} tag={RACK2['pxe_access_vlan']}")
    nets = [pxe["cidr"]] + [vlan["cidr"] for vlan in RACK2["vlans"].values()]
    vm_run("sysctl -qw net.ipv4.ip_forward=1")
    for cidr in nets:
        vm_run(
            f"iptables -t nat -C POSTROUTING -s {cidr} ! -d {cidr} -j MASQUERADE 2>/dev/null"
            f" || iptables -t nat -A POSTROUTING -s {cidr} ! -d {cidr} -j MASQUERADE"
        )
        _ensure_forward(cidr)
    log(f"OVS bridge {bridge} up; rack-2 gateway on PXE access VLAN and NAT configured")


def ensure_rack2_controller():
    """Stand up the rack-2 MAAS rack controller as a system container.

    A second registered rackd is what makes MAAS derive a distinct rack for
    rack-2 nodes (the fetcher reads each node's boot-VLAN primary rack
    controller). The container's eth1 joins br-rack2 on the PXE access VLAN
    (the rack-2 nodes' boot segment), so MAAS sees the controller on the same
    VLAN it serves DHCP to. The access-VLAN tag is OVS-internal: the container
    sees an untagged interface, so MAAS models it like any PXE NIC.
    """
    if RACK2 is None:
        return
    name = RACK2["controller"]
    if not vm_ok(f"lxc info {name} >/dev/null 2>&1"):
        log(f"launching rack-2 controller container {name}")
        vm_run(f"lxc launch ubuntu:24.04 {name} -c security.nesting=true")
        wait_for(
            f"{name} agent",
            lambda: vm_ok(f"lxc exec {name} -- true"),
            timeout=120,
            interval=5,
        )
        # Mask the default profile's eth0 (on br-pxe) so the controller lives
        # only on the rack-2 PXE access VLAN and MAAS does not associate it
        # with rack 1. Name the interface eth1 explicitly (LXD's auto-naming is
        # not stable once eth0 is masked).
        vm_run(f"lxc config device add {name} eth0 none")
        vm_run(
            f"lxc config device add {name} trunk nic nictype=bridged "
            f"parent={RACK2['bridge']} name=eth1 vlan={RACK2['pxe_access_vlan']}"
        )
    pxe = RACK2["pxe"]
    pxe_ip = _ctrl_ip(pxe["gateway"])
    setup = (
        f"ip addr replace {pxe_ip}/{pxe['cidr'].split('/')[1]} dev eth1; ip link set eth1 up; "
        f"ip route replace default via {pxe['gateway']}; "
        # /etc/resolv.conf is a systemd-resolved symlink (127.0.0.53); replace
        # it with a real resolver reachable via NAT for the snap install.
        f"rm -f /etc/resolv.conf; "
        f"printf 'nameserver 1.1.1.1\\nnameserver {PXE['gateway']}\\n' > /etc/resolv.conf"
    )
    vm_run(f"lxc exec {name} -- bash -c {shlex.quote(setup)}")
    if not vm_ok(f"lxc exec {name} -- snap list maas >/dev/null 2>&1"):
        log(f"installing maas snap in {name}")
        vm_run(f"lxc exec {name} -- snap install maas --channel={MAAS_CFG['channel']}")
    rc_hostnames = {c["hostname"] for c in maas_json("rack-controllers read")}
    if name not in rc_hostnames:
        secret = vm_out("cat /var/snap/maas/common/maas/secret")
        log(f"registering {name} as a rack controller")
        vm_run(
            f"lxc exec {name} -- maas init rack --maas-url {MAAS_URL} --secret {secret}",
        )
        wait_for(
            f"{name} registration",
            lambda: name in {c["hostname"] for c in maas_json("rack-controllers read")},
            timeout=180,
            interval=10,
        )
    log(f"rack-2 controller {name} registered")

    # Rack-2 nodes PXE boot via this controller's maas-agent boot proxy (port
    # 5248), which proxies/caches bootloaders from the region. Gate here, before
    # the rack-2 nodes are recommissioned in ensure_node_networking, on that
    # proxy actually serving bootx64.efi (the URL nodes fetch over PXE). A 502
    # means the agent is unhealthy and the nodes would fail to PXE boot and
    # stall in Commissioning. The check runs inside the container against its
    # own proxy.
    def proxy_ready():
        return vm_ok(
            f"lxc exec {name} -- curl -fsS -o /dev/null http://localhost:5248/images/bootx64.efi"
        )

    desc = f"{name} boot proxy to serve bootloaders"
    log(f"waiting for {desc} (timeout 300s)")
    deadline = time.time() + 300
    while time.time() < deadline and not proxy_ready():
        time.sleep(20)
    if not proxy_ready():
        # Self-heal a known maas-agent failure (LP#2150074, maas-kb
        # dns-stale-records-after-snap-refresh): an incomplete dqlite
        # microcluster bootstrap (database/info.yaml without cluster.yaml)
        # leaves the agent crash-looping, so configure-httpproxy-service never
        # runs and the boot proxy 502s even after the region import completes.
        # The documented fix is to stop the snap, delete the microcluster state
        # dir, and restart so it re-bootstraps. Safe in the testbed: the state
        # is already broken, and rack registration lives elsewhere (common/).
        log(
            f"{desc} stalled (boot proxy 502); applying the maas-agent microcluster "
            f"reset on {name} per LP#2150074 (maas-kb dns-stale-records-after-snap-refresh): "
            f"snap stop maas; rm -rf /var/snap/maas/current/microcluster/; snap start maas"
        )
        vm_run(
            f"lxc exec {name} -- bash -c "
            + shlex.quote(
                "snap stop maas; rm -rf /var/snap/maas/current/microcluster/; snap start maas"
            )
        )
        wait_for(desc, proxy_ready, timeout=600, interval=20)
    log(
        f"rack-2 controller {name} boot proxy serving bootloaders (proxied/cached from the region)"
    )


def ensure_rack2_networks():
    """Enable DHCP on the rack-2 PXE segment via the rack-2 controller.

    Rack-2 nodes boot on the br-rack2 PXE access VLAN. Wait for MAAS to
    discover the rack-2 controller's eth1 there, put the rack-2 PXE subnet on
    whatever fabric MAAS auto-linked it to (the subnet follows the interface,
    since VLAN/untagged interfaces cannot be reassigned), and enable DHCP with
    the rack-2 controller as primary rack so its nodes derive a distinct rack.
    """
    if RACK2 is None:
        return
    name = RACK2["controller"]
    rc = next((c for c in maas_json("rack-controllers read") if c["hostname"] == name), None)
    if rc is None:
        fatal(f"rack-2 controller {name} not registered")
    rack_id = rc["system_id"]
    pxe = RACK2["pxe"]

    iface = wait_for(
        f"{name} eth1 interface discovery",
        lambda: _rc_vlan_iface(rack_id, "eth1"),
        timeout=300,
        interval=15,
    )
    vlan = iface["vlan"]
    subnet = next((s for s in maas_json("subnets read") if s["cidr"] == pxe["cidr"]), None)
    if subnet is None:
        log(f"creating MAAS subnet {pxe['cidr']} for rack-2 PXE")
        maas_json(
            f"subnets create cidr={pxe['cidr']} vlan={vlan['id']} gateway_ip={pxe['gateway']}"
        )
    else:
        if subnet["vlan"]["id"] != vlan["id"]:
            maas_json(f"subnet update {subnet['id']} vlan={vlan['id']}")
        if subnet.get("gateway_ip") != pxe["gateway"]:
            maas_json(f"subnet update {subnet['id']} gateway_ip={pxe['gateway']}")

    rng = pxe.get("dhcp_range")
    ranges = maas_json("ipranges read")
    if rng and not any(r["start_ip"] == rng["start"] for r in ranges):
        log(f"creating rack-2 PXE DHCP range {rng['start']}-{rng['end']}")
        maas_json(f"ipranges create type=dynamic start_ip={rng['start']} end_ip={rng['end']}")
    if not vlan["dhcp_on"]:
        log(f"enabling MAAS DHCP on rack-2 PXE (primary_rack={name})")
        maas_json(
            f"vlan update {vlan['fabric_id']} {vlan['vid']} dhcp_on=true primary_rack={rack_id}"
        )
    log("rack-2 PXE segment configured with DHCP")


FRR_LINK_NET = "nt-interrack"


def _frr_data_dev(rack):
    return f"frr-{rack}-data"


def ensure_frr_routers():
    """Create one FRR ToR container per rack with eBGP over an inter-rack link.

    Each router owns its rack's data subnet gateway and an inter-rack /30
    address; eBGP (redistribute connected) advertises each rack's data subnet
    to the other so cross-rack data traffic routes by BGP.
    """
    if ROUTERS is None:
        return
    vm_run(
        f"lxc network show {FRR_LINK_NET} >/dev/null 2>&1 || "
        f"lxc network create {FRR_LINK_NET} ipv4.address=none ipv6.address=none"
    )
    rack_bridge = {"rack-1": PXE["ovs_bridge"], "rack-2": RACK2["bridge"] if RACK2 else None}
    data_tag = {
        "rack-1": VLANS["data"]["tag"],
        "rack-2": RACK2["vlans"]["data"]["tag"] if RACK2 else None,
    }
    for rack, cfg in ((r, ROUTERS[r]) for r in ("rack-1", "rack-2") if r in ROUTERS):
        host = cfg["name"]
        if not vm_ok(f"lxc info {host} >/dev/null 2>&1"):
            log(f"launching FRR router {host} for {rack}")
            vm_run(f"lxc launch ubuntu:24.04 {host} -c security.nesting=true")
            wait_for(f"{host} agent", lambda h=host: vm_ok(f"lxc exec {h} -- true"), 120, 5)
            vm_run(
                f"lxc config device add {host} data nic nictype=bridged "
                f"parent={rack_bridge[rack]} vlan={data_tag[rack]} name=eth1"
            )
            vm_run(
                f"lxc config device add {host} link nic nictype=bridged "
                f"parent={FRR_LINK_NET} name=eth2"
            )
        data_prefix = (
            VLANS["data"]["cidr"].split("/")[1]
            if rack == "rack-1"
            else RACK2["vlans"]["data"]["cidr"].split("/")[1]
        )
        link_cidr = ROUTERS["inter_rack_cidr"].split("/")[1]
        setup = (
            f"ip addr replace {cfg['data_ip']}/{data_prefix} dev eth1; ip link set eth1 up; "
            f"ip addr replace {cfg['link_ip']}/{link_cidr} dev eth2; ip link set eth2 up; "
            f"sysctl -qw net.ipv4.ip_forward=1"
        )
        vm_run(f"lxc exec {host} -- bash -c {shlex.quote(setup)}")
        if not vm_ok(f"lxc exec {host} -- which vtysh >/dev/null 2>&1"):
            log(f"installing FRR in {host}")
            # apt can fail transiently right after the container boots (mirror
            # or DNS not ready); retry until vtysh is present or we time out.
            install = (
                f"lxc exec {host} -- bash -c "
                "'export DEBIAN_FRONTEND=noninteractive; "
                "apt-get update -q && apt-get install -qy frr'"
            )
            deadline = time.time() + 240
            while True:
                vm_run(install, check=False)
                if vm_ok(f"lxc exec {host} -- which vtysh >/dev/null 2>&1"):
                    break
                if time.time() >= deadline:
                    fatal(f"FRR install in {host} failed after retries")
                time.sleep(10)
            vm_run(f"lxc exec {host} -- sed -i 's/^bgpd=no/bgpd=yes/' /etc/frr/daemons")
            vm_run(f"lxc exec {host} -- systemctl restart frr")
    _configure_ebgp()
    log("FRR ToR routers up with eBGP")


def _configure_ebgp():
    pairs = {"rack-1": "rack-2", "rack-2": "rack-1"}
    for rack, peer in pairs.items():
        if rack not in ROUTERS or peer not in ROUTERS:
            continue
        cfg, peer_cfg = ROUTERS[rack], ROUTERS[peer]
        cmds = (
            "conf t",
            f"router bgp {cfg['asn']}",
            # FRR 8.4 drops all eBGP prefixes unless an explicit policy exists;
            # this is a lab ToR with no filtering, so disable that requirement
            # and let redistribute connected advertise each rack's data subnet.
            "no bgp ebgp-requires-policy",
            f"neighbor {peer_cfg['link_ip']} remote-as {peer_cfg['asn']}",
            "redistribute connected",
            "end",
            "write memory",
        )
        vtysh = " ".join(f"-c {shlex.quote(c)}" for c in cmds)
        vm_run(f"lxc exec {cfg['name']} -- vtysh {vtysh}", check=False)


def set_nic_vlan(host, device, tag):
    vm_run(f"lxc config device set {host} {device} vlan={tag}")


def ensure_node_networking():
    """Attach per-node NIC devices with OVS tags; recommission changed nodes.

    Composed nodes first commission on the untagged PXE segment; this step
    retags their boot NIC onto the configured VLAN (which has MAAS DHCP),
    adds any additional NICs, and recommissions so MAAS records the NICs on
    the right segments.
    """
    machines = {m["hostname"]: m for m in maas_json("machines read")}
    to_commission = []
    for node in expected_nodes():
        host = node["hostname"]
        nics_cfg = node.get("nics", [])
        vlans = node_net(node)["vlans"]
        bridge = node_net(node)["bridge"]
        devices = inner_nic_devices(host)
        if not devices:
            fatal(f"inner LXD has no instance named {host}")
        names = sorted(devices)
        changed = False
        boot_dev = names[0]
        # Rack-2 nodes compose on br-pxe (the inner LXD default profile) and
        # must move their boot NIC to br-rack2 so they commission via the
        # rack-2 controller and MAAS derives rack 2.
        boot_bridge = nics_cfg[0].get("bridge", bridge)
        have_parent = devices[boot_dev].get("parent") or devices[boot_dev].get("network")
        if have_parent != boot_bridge:
            log(f"{host}: moving boot NIC {boot_dev} to {boot_bridge}")
            vm_run(
                f"lxc config device set {host} {boot_dev} nictype=bridged parent={boot_bridge}",
                check=False,
            )
            changed = True
        # A configured boot VLAN tags the NIC onto that VLAN; an untagged boot
        # NIC on a rack with a PXE access VLAN (rack 2 on the shared OVS bridge)
        # is tagged onto the access VLAN so the data VLAN cannot reach it. The
        # access tag is OVS-internal, so the node still sees an untagged NIC.
        want_tag = (
            vlans[nics_cfg[0]["vlan"]]["tag"]
            if nics_cfg[0].get("vlan")
            else node_net(node)["pxe_access_vlan"]
        )
        have_tag = devices[boot_dev].get("vlan")
        if want_tag is not None and str(want_tag) != str(have_tag or ""):
            log(f"{host}: tagging boot NIC {boot_dev} onto VLAN {want_tag}")
            set_nic_vlan(host, boot_dev, want_tag)
            changed = True
        for idx in range(1, len(nics_cfg)):
            device = f"eth{idx}"
            if device in devices:
                continue
            nic = nics_cfg[idx]
            tag = vlans[nic["vlan"]]["tag"] if nic.get("vlan") else None
            tag_arg = f" vlan={tag}" if tag is not None else ""
            log(f"{host}: adding NIC {device} on {nic['bridge']}{tag_arg}")
            vm_run(
                f"lxc config device add {host} {device} nic "
                f"nictype=bridged parent={nic['bridge']}{tag_arg}"
            )
            changed = True
        # Bond member NICs attach untagged to the bridge; the OVS bond
        # carries the VLAN tag and runs LACP, so the tag must not also sit on
        # the access port.
        for device in bond_member_devices(node):
            if device in devices:
                # A member that previously served as a tagged access NIC must
                # drop its VLAN tag: the OVS bond now carries the tag.
                if devices[device].get("vlan"):
                    log(f"{host}: clearing VLAN tag on bond member {device}")
                    vm_run(f"lxc config device unset {host} {device} vlan")
                    changed = True
                continue
            log(f"{host}: adding bond member NIC {device} on {bridge}")
            vm_run(f"lxc config device add {host} {device} nic nictype=bridged parent={bridge}")
            changed = True
        machine = machines.get(host)
        if machine is None:
            fatal(f"MAAS has no machine named {host}")
        physical = [i for i in machine["interface_set"] if i.get("type") == "physical"]
        if changed or len(physical) < expected_physical_nics(node):
            to_commission.append(host)
    for host in to_commission:
        machine = machines[host]
        if machine["status_name"] != "Ready":
            fatal(f"cannot recommission {host} in state {machine['status_name']}")
        log(f"recommissioning {host} to record NIC changes")
        maas_json(f"machine commission {machine['system_id']}")
    if to_commission:
        wait_nodes_ready(timeout=1800)


def ensure_addressing():
    """Enforce per-NIC VLAN attachment and STATIC IPs from topology.yaml.

    STATIC addressing (not AUTO/DHCP) is required because the CLI fetches
    the topology before deployment and the validators need peer IPs; AUTO
    links carry no address until deploy time. Idempotent: matching machines
    are untouched, so this also serves as the fault-clear restore path.
    """
    subnets = {s["cidr"]: s for s in maas_json("subnets read")}
    machines = {m["hostname"]: m for m in maas_json("machines read")}
    for node in expected_nodes():
        host = node["hostname"]
        machine = machines.get(host)
        if machine is None:
            fatal(f"MAAS has no machine named {host}")
        devices = inner_nic_devices(host)
        names = sorted(devices)
        by_mac = {
            (i.get("mac_address") or "").lower(): i
            for i in machine["interface_set"]
            if i.get("type") == "physical"
        }
        for idx, nic in enumerate(node.get("nics", [])):
            ip = nic.get("ip")
            if not ip or idx >= len(names):
                continue
            mac = devices[names[idx]].get("hwaddr")
            interface = by_mac.get(mac)
            if interface is None:
                fatal(f"{host}: MAAS has no interface with MAC {mac}; recommission needed")
            subnet = subnets[nic_cidr(node, nic)]
            if (interface.get("vlan") or {}).get("id") != subnet["vlan"]["id"]:
                maas_json(
                    f"interface update {machine['system_id']} {interface['id']} "
                    f"vlan={subnet['vlan']['id']}"
                )
            links = _addressed_links(interface)
            if len(links) == 1 and links[0].get("ip_address") == ip:
                continue
            for link in links:
                maas_json(
                    f"interface unlink-subnet {machine['system_id']} "
                    f"{interface['id']} id={link['id']}"
                )
            maas_json(
                f"interface link-subnet {machine['system_id']} {interface['id']} "
                f"mode=STATIC subnet={subnet['id']} ip_address={ip}"
            )
            log(f"{host} {interface['name']}: STATIC {ip} on {subnet['cidr']}")


def _bond_member_ports(node):
    """Host-side OVS port names backing a node's bond member NICs."""
    host = node["hostname"]
    ports = []
    for device in bond_member_devices(node):
        port = vm_out(f"lxc config get {host} volatile.{device}.host_name", check=False)
        if not port:
            fatal(f"{host} {device} has no host-side port; is the instance running?")
        ports.append(port)
    return ports


BOND_RECONCILER_PATH = "/usr/local/sbin/nt-bond-reconciler"
BOND_RECONCILER_CONFIG = "/etc/nt-bond-reconciler.json"
BOND_PAUSE_FLAG = "/run/nt-bond-pause"

# The reconciler runs inside the testbed VM and keeps each data node's two
# member veths aggregated into its OVS LACP bond. It is needed because MAAS
# powers nodes off in the Ready state: the host-side veths only exist while a
# node is deployed and running, and LXD assigns them fresh random names on
# every boot, so the bond cannot be created once at `up` time. The pause flag
# lets fault injection modify a bond without the reconciler reverting it.
BOND_RECONCILER_SCRIPT = r"""#!/usr/bin/env python3
import json
import os
import re
import subprocess
import time

CONFIG = "/etc/nt-bond-reconciler.json"
PAUSE = "/run/nt-bond-pause"


def sh(cmd):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True)


def host_name(host, dev):
    return sh(f"lxc config get {host} volatile.{dev}.host_name").stdout.strip()


def bond_ifaces(bond):
    # bond/show lists "member <iface>:" lines; list-ifaces is bridge-only and
    # would error on a bond port every cycle, causing a needless rebuild that
    # flaps the taps and prevents LACP from converging. An absent bond yields
    # no members, which correctly forces a (re)build.
    out = sh(f"ovs-appctl bond/show {bond}").stdout
    return set(re.findall(r"^member (\S+):", out, re.M))


def fix_guest_nic_speed(host):
    # 802.3ad bonding needs a known link speed/duplex to aggregate, but virtio
    # NICs report "Speed: Unknown", so the guest marks its bond members down
    # and never sends LACP. Force a fixed speed/duplex on any bond slave whose
    # speed is unknown (best-effort; only when the node is booted enough to
    # exec). Idempotent: skips members that already have a speed, so it does
    # not flap an established bond.
    script = (
        "for s in /sys/class/net/*/bonding/slaves; do "
        'for i in $(cat "$s" 2>/dev/null); do '
        'ethtool "$i" 2>/dev/null | grep -q "Speed: Unknown" && '
        'ethtool -s "$i" speed 1000 duplex full; done; done'
    )
    sh("lxc exec " + host + " -- bash -c '" + script + "'")


def reconcile(cfg):
    for node in cfg["nodes"]:
        bridge = node["bridge"]
        members = [host_name(node["host"], dev) for dev in node["members"]]
        if not all(members):
            continue
        if not all(sh(f"ip link show {m}").returncode == 0 for m in members):
            continue
        name, tag = node["ovs_bond"], node["tag"]
        if bond_ifaces(name) != set(members):
            sh(f"ovs-vsctl --if-exists del-port {bridge} {name}")
            for m in members:
                sh(f"ovs-vsctl --if-exists del-port {bridge} {m}")
            sh(
                f"ovs-vsctl add-bond {bridge} {name} {' '.join(members)} "
                f"bond_mode=balance-tcp lacp=active other_config:lacp-time=slow tag={tag}"
            )
        fix_guest_nic_speed(node["host"])


def main():
    while True:
        if not os.path.exists(PAUSE):
            try:
                cfg = json.load(open(CONFIG))
                reconcile(cfg)
            except Exception:
                pass
        time.sleep(10)


if __name__ == "__main__":
    main()
"""


def build_ovs_bond(node):
    """(Re)build a node's unified OVS LACP bond from its running member veths."""
    net = node_net(node)
    bridge = net["bridge"]
    name = ovs_bond_name(node["hostname"])
    tag = net["vlans"][node_bond(node)["vlan"]]["tag"]
    ports = _bond_member_ports(node)
    for extra in swap_extra_names(node["hostname"]).values():
        vm_run(f"ovs-vsctl --if-exists del-port {bridge} {extra}", check=False)
    vm_run(f"ovs-vsctl --if-exists del-port {bridge} {name}")
    for port in ports:
        vm_run(f"ovs-vsctl --if-exists del-port {bridge} {port}")
    vm_run(
        f"ovs-vsctl add-bond {bridge} {name} {' '.join(ports)} "
        f"bond_mode=balance-tcp lacp=active other_config:lacp-time=slow tag={tag}"
    )
    log(f"{node['hostname']}: OVS bond {name} over {ports} (LACP active/slow, VLAN {tag})")


def ensure_bond_reconciler():
    """Install and start the in-VM OVS bond reconciler service.

    The data nodes' OVS bonds cannot be created at `up` time (the nodes are
    powered off in Ready), so a small systemd service inside the VM aggregates
    each node's member veths into its bond whenever they appear after a deploy.
    """
    bonded = [n for n in expected_nodes() if node_bond(n)]
    if not bonded:
        return
    config = {
        "nodes": [
            {
                "host": n["hostname"],
                "bridge": node_net(n)["bridge"],
                "ovs_bond": ovs_bond_name(n["hostname"]),
                "tag": node_net(n)["vlans"][node_bond(n)["vlan"]]["tag"],
                "members": bond_member_devices(n),
            }
            for n in bonded
        ],
    }
    vm_run(f"cat > {BOND_RECONCILER_CONFIG} <<'NTEOF'\n{json.dumps(config, indent=2)}\nNTEOF")
    vm_run(f"cat > {BOND_RECONCILER_PATH} <<'NTEOF'\n{BOND_RECONCILER_SCRIPT}\nNTEOF")
    vm_run(f"chmod +x {BOND_RECONCILER_PATH}")
    unit = (
        "[Unit]\nDescription=nt-testbed OVS bond reconciler\n\n"
        f"[Service]\nExecStart=/usr/bin/python3 {BOND_RECONCILER_PATH}\nRestart=always\n\n"
        "[Install]\nWantedBy=multi-user.target\n"
    )
    vm_run(f"cat > /etc/systemd/system/nt-bond-reconciler.service <<'NTEOF'\n{unit}\nNTEOF")
    vm_run(f"rm -f {BOND_PAUSE_FLAG}")
    vm_run("systemctl daemon-reload && systemctl enable --now nt-bond-reconciler.service")
    vm_run("systemctl restart nt-bond-reconciler.service")
    log("OVS bond reconciler service installed and running")


def ensure_maas_bonds():
    """Create the matching MAAS 802.3ad bond over each node's member NICs.

    The members commission as plain physical interfaces (the data VLAN has no
    DHCP or LLDP, so MAAS leaves them on the default fabric). This step bonds
    them in MAAS with mode 802.3ad / slow LACP rate, moves the bond onto the
    data VLAN, and assigns the STATIC data IP so the topology JSON carries the
    bond before deployment. Idempotent: an existing bond with the right
    address is left untouched, so it also serves as a fault-clear restore.
    """
    subnets = {s["cidr"]: s for s in maas_json("subnets read")}
    machines = {m["hostname"]: m for m in maas_json("machines read")}
    for node in expected_nodes():
        bond = node_bond(node)
        if not bond:
            continue
        host = node["hostname"]
        machine = machines.get(host)
        if machine is None:
            fatal(f"MAAS has no machine named {host}")
        sysid = machine["system_id"]
        devices = inner_nic_devices(host)
        member_macs = [devices[d]["hwaddr"] for d in bond_member_devices(node) if d in devices]
        by_mac = {
            (i.get("mac_address") or "").lower(): i
            for i in machine["interface_set"]
            if i.get("type") == "physical"
        }
        members = [by_mac[m] for m in member_macs if m in by_mac]
        if len(members) != len(bond_member_devices(node)):
            fatal(f"{host}: MAAS missing physical interfaces for bond members; recommission")
        subnet = subnets[node_net(node)["vlans"][bond["vlan"]]["cidr"]]
        bond_iface = next(
            (
                i
                for i in machine["interface_set"]
                if i.get("type") == "bond" and i["name"] == bond["name"]
            ),
            None,
        )
        if bond_iface is None:
            # MAAS requires bond parents to share a VLAN and carry no subnet
            # links. The untagged members commission onto separate auto-created
            # fabrics, so move both onto the data VLAN and drop their links
            # before bonding (a member may also have been a tagged data NIC
            # before this stage).
            for member in members:
                # Unlink first: changing the VLAN invalidates the link ids.
                for link in _addressed_links(member):
                    maas_json(f"interface unlink-subnet {sysid} {member['id']} id={link['id']}")
                if (member.get("vlan") or {}).get("id") != subnet["vlan"]["id"]:
                    maas_json(
                        f"interface update {sysid} {member['id']} vlan={subnet['vlan']['id']}"
                    )
            parents = " ".join(f"parents={i['id']}" for i in members)
            member_names = [i["name"] for i in members]
            log(f"{host}: creating MAAS bond {bond['name']} (802.3ad) over {member_names}")
            bond_iface = maas_json(
                f"interfaces create-bond {sysid} name={bond['name']} {parents} "
                f"bond_mode={bond['mode']} bond_lacp_rate=slow"
            )
        if (bond_iface.get("vlan") or {}).get("id") != subnet["vlan"]["id"]:
            maas_json(f"interface update {sysid} {bond_iface['id']} vlan={subnet['vlan']['id']}")
        links = _addressed_links(bond_iface)
        if len(links) == 1 and links[0].get("ip_address") == bond["ip"]:
            continue
        for link in links:
            maas_json(f"interface unlink-subnet {sysid} {bond_iface['id']} id={link['id']}")
        maas_json(
            f"interface link-subnet {sysid} {bond_iface['id']} "
            f"mode=STATIC subnet={subnet['id']} ip_address={bond['ip']}"
        )
        log(f"{host} {bond['name']}: STATIC {bond['ip']} on {subnet['cidr']}")


JUJU_CONTROLLER = "nt"
MAAS_CLOUD = "maas-testbed"
JUJU_APP = "network-tester"  # charm application name the CLI deploys


def ensure_juju():
    """Bootstrap a Juju controller on the inner LXD and register the MAAS cloud.

    The controller container attaches to the management/PXE bridge through the
    inner LXD default profile, so MAAS-deployed nodes reach the controller API
    without traversing the data fabric, and the controller stays outside the
    topology under test (design D18). charmcraft is installed so the charm can
    be packed inside the VM when the host lacks charmcraft.
    """
    for snap, args in (("juju", ""), ("charmcraft", "--classic")):
        if not vm_ok(f"snap list {snap} >/dev/null 2>&1"):
            log(f"installing snap {snap}")
            vm_run(f"snap install {snap} {args}")
    # the strictly confined juju snap cannot create this directory itself
    vm_run("mkdir -p /root/.local/share/juju")

    controllers = vm_run("juju controllers --format json", check=False, capture=True)
    have_controller = False
    if controllers.returncode == 0 and controllers.stdout.strip():
        parsed = json.loads(controllers.stdout)
        have_controller = JUJU_CONTROLLER in (parsed.get("controllers") or {})
    if not have_controller:
        log(f"bootstrapping Juju controller {JUJU_CONTROLLER} on the inner LXD")
        vm_run(f"juju bootstrap localhost {JUJU_CONTROLLER}")

    def controller_json(cmd, key):
        result = vm_run(
            f"juju {cmd} --controller {JUJU_CONTROLLER} --format json", check=False, capture=True
        )
        if result.returncode != 0 or not result.stdout.strip():
            return {}
        parsed = json.loads(result.stdout)
        # `juju clouds` returns cloud names at the top level; `juju
        # credentials` nests them under a wrapper key
        return parsed.get(key, parsed) or {}

    if MAAS_CLOUD not in controller_json("clouds", "clouds"):
        log(f"registering testbed MAAS as Juju cloud {MAAS_CLOUD}")
        cloud_yaml = (
            f"clouds:\n  {MAAS_CLOUD}:\n    type: maas\n"
            f"    auth-types: [oauth1]\n    endpoint: {MAAS_URL}\n"
        )
        vm_run(f"cat > /root/nt-cloud.yaml <<'EOF'\n{cloud_yaml}EOF")
        vm_run(f"juju add-cloud {MAAS_CLOUD} -f /root/nt-cloud.yaml --client || true")
        vm_run(
            f"juju add-cloud {MAAS_CLOUD} -f /root/nt-cloud.yaml --controller {JUJU_CONTROLLER}"
        )
    key = vm_out(f"maas apikey --username {MAAS_CFG['admin_user']}")
    cred_yaml = (
        f"credentials:\n  {MAAS_CLOUD}:\n    admin:\n"
        f"      auth-type: oauth1\n      maas-oauth: {key}\n"
    )
    vm_run(f"cat > /root/nt-cred.yaml <<'EOF'\n{cred_yaml}EOF")
    # The client-local credential is required so python-libjuju resolves it by
    # name when creating models. Without it, controller.add_model() finds no
    # local credential, leaves it unset, and the controller falls back to its
    # own bootstrap (LXD certificate) credential, which MAAS rejects with
    # "certificate auth-type not supported". The `network-tester` CLI uses
    # libjuju, so the client store must carry the MAAS credential.
    vm_run(f"juju add-credential {MAAS_CLOUD} -f /root/nt-cred.yaml --client 2>/dev/null || true")
    if MAAS_CLOUD not in controller_json("credentials", "controller-credentials"):
        log(f"adding MAAS credential for cloud {MAAS_CLOUD}")
        # add-credential --controller still adds the controller credential but
        # exits non-zero when the client-local copy added above already exists
        # ("credential already exists locally"); tolerate that and verify the
        # controller credential actually landed.
        vm_run(
            f"juju add-credential {MAAS_CLOUD} -f /root/nt-cred.yaml "
            f"--controller {JUJU_CONTROLLER} || true"
        )
        if MAAS_CLOUD not in controller_json("credentials", "controller-credentials"):
            fatal(f"failed to add MAAS credential to controller {JUJU_CONTROLLER}")
    log(f"Juju controller {JUJU_CONTROLLER} is up with cloud {MAAS_CLOUD} registered")


def ensure_charm_packed():
    """Pack the charm (host charmcraft preferred, VM fallback); return its filename."""
    charm_dir = REPO_ROOT / "charm"
    if shutil.which("charmcraft"):
        log("packing charm on the host")
        host_run(["charmcraft", "pack"], cwd=str(charm_dir))
        charms = sorted(charm_dir.glob("*.charm"))
        if not charms:
            fatal("charmcraft pack produced no .charm file")
        return charms[0].name
    log("host has no charmcraft; packing inside the testbed VM (destructive mode)")
    sync_tree()
    vm_run(f"cd {VM_TREE}/charm && charmcraft pack --destructive-mode")
    name = vm_out(f"ls {VM_TREE}/charm/*.charm | head -1")
    if not name:
        fatal("charmcraft pack inside the VM produced no .charm file")
    return Path(name).name


def sync_tree():
    log(f"syncing working tree to {VM}:{VM_TREE}")
    # recreate the tree so host-side deletions propagate; uv recreates the
    # venvs from its cache in seconds
    vm_run(f"rm -rf {VM_TREE} && mkdir -p {VM_TREE}")
    excludes = [f"--exclude={e}" for e in SYNC_EXCLUDES]
    tar_out = subprocess.Popen(
        ["tar", "-C", str(REPO_ROOT), *excludes, "-cf", "-", "."],
        stdout=subprocess.PIPE,
    )
    untar = subprocess.run(
        ["lxc", "exec", VM, "--", "tar", "-C", VM_TREE, "-xf", "-"],
        stdin=tar_out.stdout,
    )
    tar_out.wait()
    if tar_out.returncode != 0 or untar.returncode != 0:
        fatal("working tree sync failed")
    vm_run(f"cd {VM_TREE} && uv sync --quiet")
    log("working tree synced and uv venv created inside the VM")


def vm_host_address():
    """Return the testbed VM's host-side IPv4 address (on the LXD NAT bridge)."""
    result = host_run(["lxc", "list", VM, "--format", "json"], capture=True)
    instances = [i for i in json.loads(result.stdout) if i["name"] == VM]
    if not instances or not instances[0].get("state"):
        return None
    for name, net in (instances[0]["state"].get("network") or {}).items():
        if name == "lo":
            continue
        for addr in net.get("addresses", []):
            if addr["family"] == "inet" and not addr["address"].startswith("10.100."):
                return addr["address"]
    return None


def report_ui_address():
    ip = vm_host_address()
    if ip:
        log(
            f"MAAS UI reachable from the host at http://{ip}:5240/MAAS "
            f"({MAAS_CFG['admin_user']}/{MAAS_CFG['admin_password']})"
        )
    else:
        log("note: could not determine the VM host-side address for the MAAS UI")


def cmd_up():
    ensure_vm()
    ensure_packages()
    ensure_bridge()
    ensure_maas()
    ensure_subnet_dhcp()
    ensure_images()
    # Model the management VLANs and the data fabric before the inner LXD
    # exists, so the rack-controller refresh runs against a clean interface
    # set (no churning node taps) when the VLAN ports are added.
    ensure_vlan_networks()
    ensure_dhcp_rebind()
    ensure_data_segments()
    # Create br-rack2 only after rack-1's VLAN discovery so its extra bridges
    # do not perturb MAAS's fabric/VLAN auto-linking for rack 1.
    ensure_rack2_bridge()
    ensure_inner_lxd()
    ensure_rack2_controller()
    ensure_rack2_networks()
    ensure_frr_routers()
    ensure_data_routes()
    ensure_vm_host()
    ensure_machines()
    ensure_node_networking()
    ensure_maas_bonds()
    ensure_bond_reconciler()
    ensure_addressing()
    sync_tree()
    ensure_juju()
    report_ui_address()
    log("testbed is up")


