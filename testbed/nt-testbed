             "fabric": "fabric-mgmt", "fabric_class": "management", "vlan_tag": 10,
             "subnet_cidr": "10.10.1.0/24", "ip": "10.10.%d.%d" % (r, n + 2), "gateway_ip": "10.10.%d.1" % r},
            {"name": "bond0", "type": "bond", "mac": "52:54:00:%02x:%02x:02" % (r, n),
             "fabric": "data-%s" % rack, "fabric_class": "data", "vlan_tag": 100,
             "subnet_cidr": "10.%d.0.0/24" % r, "ip": "10.%d.0.%d" % (r, n), "gateway_ip": "10.%d.0.254" % r,
             "bond_members": [{"name": "ens3", "mac": "52:54:00:%02x:%02x:03" % (r, n)},
                              {"name": "ens4", "mac": "52:54:00:%02x:%02x:04" % (r, n)}]}]})
topology = {"schema_version": "1", "scope": {"selector": "all"}, "fabrics": [],
    "machines": machines, "reachability_model": {"rules": {"cross-rack-data-routing": {"parameters": {}}}}}
open("/root/nt-scale-topology.json", "w").write(json.dumps(topology))
"""


# Deploys the scale charm with the synthetic topology resource through the same
# libjuju facade the CLI uses for real runs. libjuju runs in the unconfined uv
# venv (so it reads the charm/resource under /root directly, unlike the strictly
# confined juju CLI snap) and supports num_units=0, so the application and its
# resource upload to the controller without ever requesting a MAAS machine. A
# clean deploy is the empirical proof the controller accepts the resource at
# this size; get_resources confirms the topology resource registered.
SCALE_DEPLOY_PY = r"""
import asyncio
import sys

from cli.juju_run import LibjujuFacade, APP_NAME

charm, topo, model = sys.argv[1], sys.argv[2], sys.argv[3]


async def main():
    facade = LibjujuFacade()
    await facade.connect()
    try:
        await facade.deploy(model, charm, {"topology": topo})
        names = []
        try:
            m = await facade._model(model)
            resources = await m.applications[APP_NAME].get_resources()
            names = sorted(resources.keys())
        except Exception as exc:
            print("RESOURCE-ENUM-WARN: %s" % exc)
        print("RESOURCES: %s" % ",".join(names))
        print("DEPLOY-OK")
    finally:
        await facade.disconnect()


asyncio.run(main())
"""


def verify_scale():
    """Phase 8 empirical scale check: the testbed Juju controller accepts a
    synthetic 200-node topology file resource.

    The topology resource grows with cluster node count, so this confirms Juju
    accepts it at datacenter scale (the size unit test records the byte budget
    and the no-chunking decision). The charm is deployed with num_units=0 via
    the libjuju facade, so the application and its resource upload to the
    controller without ever requesting a MAAS machine: this isolates resource
    acceptance from node bring-up.
    """
    charm_name = ensure_charm_packed()
    sync_tree()
    ensure_juju()
    problems = []
    model = "nt-scale"

    log("verify scale: generating a synthetic 200-node topology resource")
    vm_run(f"python3 - <<'PY'\n{SCALE_TOPOLOGY_GEN}\nPY")
    size = int(vm_out("stat -c %s /root/nt-scale-topology.json"))
    log(f"verify scale: 200-node topology resource is {size} bytes")

    # add-model/destroy-model go through the juju CLI (they touch no local
    # files, so snap confinement is irrelevant); the charm + resource deploy
    # goes through libjuju (SCALE_DEPLOY_PY) because the confined juju CLI snap
    # cannot read a local charm or resource file under /root.
    vm_run(
        f"juju destroy-model --no-prompt --force --timeout 5m {model} 2>/dev/null || true",
        check=False,
    )
    vm_run(f"juju add-model -c {JUJU_CONTROLLER} {model} {MAAS_CLOUD}")
    try:
        result = vm_run(
            f"cd {VM_TREE} && uv run python - "
            f"charm/{charm_name} /root/nt-scale-topology.json {model} "
            f"<<'PY'\n{SCALE_DEPLOY_PY}\nPY",
            check=False,
            capture=True,
        )
        out = result.stdout + result.stderr
        if result.returncode != 0 or "DEPLOY-OK" not in out:
            problems.append(
                f"libjuju deploy of the {size}-byte 200-node topology resource failed:\n{out}"
            )
        else:
            resource_line = next((l for l in out.splitlines() if l.startswith("RESOURCES:")), "")
            names = resource_line.partition(":")[2].split(",")
            if "topology" not in [n.strip() for n in names]:
                problems.append(f"topology resource not registered after deploy:\n{out}")
    finally:
        vm_run(
            f"juju destroy-model --no-prompt --force --timeout 5m {model}",
            check=False,
        )

    if problems:
        for problem in problems:
            log(f"FAIL: {problem}")
        sys.exit(1)
    log(f"verify scale: PASS (Juju accepted the {size}-byte 200-node topology resource)")


