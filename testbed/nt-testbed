def cmd_down():
    if vm_exists():
        log(f"deleting VM {VM}")
        host_run(["lxc", "delete", "--force", VM])
    else:
        log(f"VM {VM} does not exist")
    leftovers = []
    if vm_exists():
        leftovers.append(f"VM {VM} still present")
    for kind in ("profile", "network"):
        result = host_run(["lxc", kind, "list", "--format", "json"], capture=True)
        for item in json.loads(result.stdout):
            if item["name"].startswith("nt-") or item["name"] == PXE["bridge"]:
                leftovers.append(f"host {kind} {item['name']}")
    if leftovers:
        fatal("host-side leftovers found: " + ", ".join(leftovers))
    log("testbed removed; no host-side leftovers")


def cmd_status():
    result = host_run(["lxc", "list", VM, "--format", "json"], capture=True)
    instances = [i for i in json.loads(result.stdout) if i["name"] == VM]
    if not instances:
        log(f"VM {VM} does not exist (run `nt-testbed up`)")
        return
    log(f"VM {VM}: {instances[0]['status']}")
    if instances[0]["status"] != "Running":
        return
    if not vm_ok("maas status >/dev/null 2>&1"):
        log("MAAS: not initialised")
        return
    machines = maas_json("machines read", check=False) or []
    log(f"MAAS: initialised, {len(machines)} machine(s)")
    for m in machines:
        log(f"  {m['hostname']}: {m['status_name']}")
    hosts = maas_json("vm-hosts read", check=False) or []
    for h in hosts:
        used, total = h["used"], h["total"]
        log(
            f"  VM host {h['name']}: {used['cores']}/{total['cores']} cores, "
            f"{used['memory']}/{total['memory']} MiB used"
        )
    report_ui_address()


def cmd_shell():
    if vm_ok(f"test -d {VM_TREE}"):
        os.execvp("lxc", ["lxc", "exec", VM, "--cwd", VM_TREE, "--", "bash", "-l"])
    os.execvp("lxc", ["lxc", "exec", VM, "--", "bash", "-l"])


def verify_foundation():
    """Assert exactly the composed machines are Ready with expected records."""
    machines = maas_json("machines read")
    expected = {n["hostname"] for n in expected_nodes()}
    actual = {m["hostname"] for m in machines}
    failures = []
    if actual != expected:
        failures.append(f"machine set mismatch: expected {sorted(expected)}, got {sorted(actual)}")
    by_hostname = {n["hostname"]: n for n in expected_nodes()}
    for m in machines:
        node = by_hostname.get(m["hostname"])
        if node is None:
            continue
        if m["status_name"] != "Ready":
            failures.append(f"{m['hostname']}: status {m['status_name']}, expected Ready")
        nics = m.get("interface_set", [])
        if not nics or not all(n.get("mac_address") for n in nics):
            failures.append(f"{m['hostname']}: missing interface or MAC record")
        subnets = {
            link["subnet"]["cidr"]
            for nic in nics
            for link in nic.get("links", [])
            if link.get("subnet")
        }
        wanted = {nic_cidr(node, nic) for nic in node.get("nics", [])}
        if not wanted <= subnets:
            failures.append(
                f"{m['hostname']}: missing subnet records for {sorted(wanted - subnets)} "
                f"(has {sorted(subnets)})"
            )
    if failures:
        for failure in failures:
            log(f"FAIL: {failure}")
        sys.exit(1)
    log(f"verify foundation: PASS ({len(expected)} machines Ready with configured subnets)")


def network_tester_run(extra_args):
    """Run the network-tester CLI inside the testbed VM against its MAAS."""
    key = vm_out(f"maas apikey --username {MAAS_CFG['admin_user']}")
    return vm_run(
        f"cd {VM_TREE} && uv run network-tester run {extra_args} "
        f"--maas-url {MAAS_URL} --maas-key {key}",
        check=False,
        capture=True,
    )


def verify_topology():
    """Dry-run against the testbed MAAS, plus the incomplete-config fault.

    Since stage 5 the data nodes have a data-VLAN NIC (role data) and the
    additional small node lives on the oam VLAN (role bmc-oam); per-node
    expectations come from topology.yaml.
    """
    sync_tree()
    problems = []

    log("verify topology: clean dry-run --all")
    result = network_tester_run("--dry-run --all")
    output = result.stdout + result.stderr
    if result.returncode != 0:
        problems.append(f"clean dry-run exited {result.returncode}:\n{output}")
    else:
        for node in expected_nodes():
            role = node.get("role", "data")
            pattern = rf"{node['hostname']} \(\w+\) rack=\S+ role={role}"
            if not re.search(pattern, output):
                problems.append(
                    f"dry-run output missing '{node['hostname']} ... role={role}':\n{output}"
                )
        for section in ("Would run:", "Would skip:"):
            if section not in output:
                problems.append(f"dry-run output missing '{section}' section")
        if "vlan-neighbor-validator" not in output:
            problems.append("dry-run output lists no vlan-neighbor checks")

    target = expected_nodes()[0]["hostname"]
    log(f"verify topology: incomplete-config fault on {target}")
    fault_incomplete_config([target])
    result = network_tester_run("--all")
    output = result.stdout + result.stderr
    if result.returncode == 0:
        problems.append("run --all succeeded despite incomplete config")
    elif "Pre-flight validation failed" not in output or target not in output:
        problems.append(f"pre-flight failure does not name {target}:\n{output}")

    log("verify topology: fault clear and re-check")
    clear_faults()
    result = network_tester_run("--dry-run --all")
    if result.returncode != 0:
        problems.append(
            f"dry-run after fault clear exited {result.returncode}:\n"
            f"{result.stdout + result.stderr}"
        )

    if problems:
        for problem in problems:
            log(f"FAIL: {problem}")
        sys.exit(1)
    log("verify topology: PASS (dry-run roles/checks, fault, and recovery)")


def vm_juju_models():
    """Names of network-test-* models on the testbed controller."""
    raw = vm_out("juju models --format json", check=False)
    if not raw:
        return []
    names = []
    for model in json.loads(raw).get("models", []):
        name = model.get("short-name") or model.get("name", "")
        name = name.split("/")[-1]
        if name.startswith("network-test-"):
            names.append(name)
    return names


def destroy_test_models():
    for name in vm_juju_models():
        log(f"destroying leftover model {name}")
        vm_run(f"juju destroy-model --no-prompt --force --timeout 10m {name}")


def wait_nodes_ready(timeout=900):
    expected = {n["hostname"] for n in expected_nodes()}

    def all_ready():
        machines = maas_json("machines read")
        states = {m["hostname"]: m["status_name"] for m in machines if m["hostname"] in expected}
        log(f"machine states: {states}")
        return len(states) == len(expected) and all(s == "Ready" for s in states.values())

    wait_for("nodes to return to Ready in MAAS", all_ready, timeout=timeout, interval=20)


def verify_skeleton():
    """End-to-end walking-skeleton gate: deploy, probe, collect, report, teardown.

    Runs the jubilant charm integration test against the testbed controller,
    then the full `network-tester run --all` pipeline on the MAAS cloud
    (auto-destroy path), then the --keep-model / status / --reuse-model path.
    """
    charm_name = ensure_charm_packed()
    sync_tree()
    ensure_juju()
    destroy_test_models()
    problems = []

    log("verify skeleton: jubilant charm integration test (LXD-backed model)")
    result = vm_run(
        f"cd {VM_TREE}/charm && NT_CHARM_PATH={VM_TREE}/charm/{charm_name} "
        "uv run --group integration pytest tests/integration -q",
        check=False,
        capture=True,
    )
    if result.returncode != 0:
        problems.append(f"jubilant test failed:\n{result.stdout}\n{result.stderr}")

    deploy_args = f"--charm charm/{charm_name} --cloud {MAAS_CLOUD} --wait-timeout 1800"
    node_count = len(expected_nodes())

    log("verify skeleton: full run with auto-destroy")
    result = network_tester_run(f"--all {deploy_args}")
    output = result.stdout + result.stderr
    if result.returncode != 0:
        problems.append(f"run --all exited {result.returncode}:\n{output}")
    else:
        for marker in (
            "triggering probe run",
            f"collecting results from {node_count} unit(s)",
            "report written to ",
            "destroying model network-test-",
        ):
            if marker not in output:
                problems.append(f"run --all output missing '{marker}':\n{output}")
        if not re.search(r"All \d+ checks passed\.", output):
            problems.append(f"run --all output missing 'All N checks passed.':\n{output}")
        match = re.search(r"report written to (\S+network-test-\S+\.json)", output)
        if match:
            report_raw = vm_out(f"cat {shlex.quote(match.group(1))}", check=False)
            try:
                report = json.loads(report_raw)
                if report.get("missing_nodes"):
                    problems.append(f"report has missing nodes: {report['missing_nodes']}")
                if report.get("schema_version") != "1":
                    problems.append("report schema_version is not '1'")
            except json.JSONDecodeError:
                problems.append(f"report file is not valid JSON: {match.group(1)}")
            text_report = match.group(1)[: -len(".json")] + ".txt"
            if not vm_ok(f"test -f {shlex.quote(text_report)}"):
                problems.append(f"text report missing: {text_report}")
        if vm_juju_models():
            problems.append(f"model not auto-destroyed: {vm_juju_models()}")
        else:
            wait_nodes_ready()

    if not problems:
        log("verify skeleton: keep-model run, status, and reuse-model re-trigger")
        result = network_tester_run(f"--all --keep-model {deploy_args}")
        output = result.stdout + result.stderr
        match = re.search(r"Model (network-test-\S+) kept", output)
        if result.returncode != 0 or not match:
            problems.append(f"keep-model run failed ({result.returncode}):\n{output}")
        else:
            model = match.group(1)
            status_out = vm_run(
                f"cd {VM_TREE} && uv run network-tester status", check=False, capture=True
            )
            status_text = status_out.stdout + status_out.stderr
            if status_out.returncode != 0 or model not in status_text:
                problems.append(f"status does not show kept model {model}:\n{status_text}")
            elif "probe complete" not in status_text:
                problems.append(f"status does not show probe completion:\n{status_text}")

            result = network_tester_run(f"--reuse-model {model} --wait-timeout 600")
            output = result.stdout + result.stderr
            if result.returncode != 0 or not re.search(r"All \d+ checks passed\.", output):
                problems.append(f"reuse-model run failed ({result.returncode}):\n{output}")

            log(f"destroying kept model {model}")
            vm_run(f"juju destroy-model --no-prompt --force --timeout 15m {model}", check=False)
            wait_nodes_ready()

    if problems:
        for problem in problems:
            log(f"FAIL: {problem}")
        sys.exit(1)
    log("verify skeleton: PASS (jubilant test, full pipeline, keep/status/reuse)")


def report_from_output(output):
    """Parse the JSON report referenced by a network-tester run's output."""
    match = re.search(r"report written to (\S+network-test-\S+\.json)", output)
    if not match:
        return None
    raw = vm_out(f"cat {shlex.quote(match.group(1))}", check=False)
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return None


def verify_vlan():
    """Stage 5 gate: clean pass, wrong-vlan fault findings, partial-scope skips."""
    charm_name = ensure_charm_packed()
    sync_tree()
    ensure_juju()
    destroy_test_models()
    clear_faults()
    problems = []
    deploy_args = f"--charm charm/{charm_name} --cloud {MAAS_CLOUD} --wait-timeout 1800"
    machine_ids = {m["hostname"]: m["system_id"] for m in maas_json("machines read")}

    log("verify vlan: clean run (model kept for the fault re-trigger)")
    result = network_tester_run(f"--all --keep-model {deploy_args}")
    output = result.stdout + result.stderr
    model_match = re.search(r"Model (network-test-\S+) kept", output)
    report = report_from_output(output)
    if result.returncode != 0 or model_match is None or report is None:
        problems.append(f"clean run failed ({result.returncode}):\n{output}")
    else:
        if report["definitive_failures"]:
            problems.append(
                "clean run has failures:\n" + json.dumps(report["definitive_failures"], indent=2)
            )
        if report["summary"]["passed_count"] < 1:
            problems.append(f"clean run passed no VLAN checks:\n{json.dumps(report['summary'])}")
        if report["warnings"]:
            problems.append("clean run has warnings:\n" + json.dumps(report["warnings"], indent=2))

    if not problems and model_match:
        model = model_match.group(1)
        target = "r1-data-02"
        data_mac = vm_out(f"lxc config get {target} volatile.eth1.hwaddr").lower()
        log(f"verify vlan: wrong-vlan fault on {target}")
        fault_wrong_vlan([target])
        result = network_tester_run(f"--reuse-model {model} --wait-timeout 900")
        output = result.stdout + result.stderr
        report = report_from_output(output)
        if report is None:
            problems.append(f"fault run produced no report:\n{output}")
        else:
            failures = report["definitive_failures"]
            missing_peer = [
                f
                for f in failures
                if f["type"] in ("missing-l2-neighbor", "icmp-unreachable")
                and f.get("details", {}).get("peer_system_id") == machine_ids[target]
            ]
            if not missing_peer:
                problems.append(
                    f"fault run records no missing-peer failure for {target}:\n"
                    + json.dumps(failures, indent=2)
                )
            elif not any("verify VLAN assignment" in f.get("hint", "") for f in missing_peer):
                problems.append("missing-peer failure lacks the remediation hint")
            unexpected = [
                f
                for f in failures
                if f["type"] == "unexpected-l2-neighbor"
                and f.get("details", {}).get("mac") == data_mac
            ]
            if not unexpected:
                problems.append(
                    f"no unexpected-l2-neighbor finding for {target}'s data NIC {data_mac}:\n"
                    + json.dumps(failures, indent=2)
                )
            if result.returncode != 1:
                problems.append(f"fault run exited {result.returncode}, expected 1")
        log("verify vlan: clearing fault and destroying kept model")
        clear_faults()
        vm_run(f"juju destroy-model --no-prompt --force --timeout 15m {model}", check=False)
        wait_nodes_ready()

    if not problems:
        log("verify vlan: partial-scope run (--nodes r1-data-01)")
        result = network_tester_run(f"--nodes r1-data-01 {deploy_args}")
        output = result.stdout + result.stderr
        report = report_from_output(output)
        excluded = machine_ids["r1-data-02"]
        if result.returncode != 0 or report is None:
            problems.append(f"partial-scope run failed ({result.returncode}):\n{output}")
        elif not any(e.get("peer") == excluded for e in report["skipped_checks"]):
            problems.append(
                f"partial-scope report lacks a grouped skip entry for {excluded}:\n"
                + json.dumps(report["skipped_checks"], indent=2)
            )
        wait_nodes_ready()

    if problems:
        for problem in problems:
            log(f"FAIL: {problem}")
        sys.exit(1)
    log("verify vlan: PASS (clean, wrong-vlan fault, partial scope)")


def unit_probe_outputs(model):
    """Cat /var/log/network-tester/probe-output.json from every unit, keyed by
    the reporting node's hostname. Used to inspect raw bond audit data the
    report does not surface."""
    raw = vm_out(f"juju status -m {model} --format json", check=False)
    outputs = {}
    if not raw:
        return outputs
    data = json.loads(raw)
    for app in (data.get("applications") or {}).values():
        for unit in app.get("units") or {}:
            text = vm_out(
                f"juju exec -m {model} --unit {unit} -- "
                "cat /var/log/network-tester/probe-output.json",
                check=False,
            )
            try:
                doc = json.loads(text)
            except json.JSONDecodeError:
                continue
            host = (doc.get("node") or {}).get("hostname")
            if host:
                outputs[host] = doc
    return outputs


def _check_clean_bonds(outputs, bonded, problems):
    """Assert each bonded node reports bond_mode/bond_cabling pass and that at
    least one member captured an LACP PDU in the 35s window (6.12 empirical)."""
    for host in bonded:
        doc = outputs.get(host)
        if doc is None:
            problems.append(f"no probe output collected for bonded node {host}")
            continue
        bonds = (doc.get("bond_validator") or {}).get("bonds") or []
        if not bonds:
            problems.append(f"{host}: bond_validator recorded no bonds")
            continue
        bond = bonds[0]
        if bond.get("bond_mode") != "pass":
            problems.append(
                f"{host}: bond_mode is {bond.get('bond_mode')}, expected pass:\n"
                + json.dumps(bond, indent=2)
            )
        if bond.get("bond_cabling") != "pass":
            problems.append(f"{host}: bond_cabling is {bond.get('bond_cabling')}, expected pass")
        if not any(m.get("lacp_advertised") for m in bond.get("members", [])):
            problems.append(
                f"{host}: no bond member captured an LACP PDU in the 35s window (6.12):\n"
                + json.dumps(bond, indent=2)
            )


# (fault name, expected report finding type, required hint substring)
BOND_FAULT_CASES = (
    ("bond-static", "bond-mode-mismatch", "static bonding"),
    ("bond-passive", "bond-mode-mismatch", "lacp_active off"),
    ("bond-swap", "asymmetric-bond-cable", "different switches"),
)


def verify_bond():
    """Stage 6 gate: clean LACP pass plus the three bond fault scenarios.

    The clean run confirms the validator captures real LACP PDUs from the OVS
    bond (6.12) and reports bond mode and cabling as pass. Each fault is then
    injected on the kept model and re-triggered via --reuse-model, asserting
    the expected finding type and remediation hint appear in the report.
    """
    charm_name = ensure_charm_packed()
    sync_tree()
    ensure_juju()
    destroy_test_models()
    clear_faults()
    problems = []
    deploy_args = f"--charm charm/{charm_name} --cloud {MAAS_CLOUD} --wait-timeout 1800"
    bonded = [n["hostname"] for n in expected_nodes() if node_bond(n)]

    log("verify bond: clean run (model kept for the fault re-triggers)")
    result = network_tester_run(f"--all --keep-model {deploy_args}")
    output = result.stdout + result.stderr
    match = re.search(r"Model (network-test-\S+) kept", output)
    report = report_from_output(output)
    model = match.group(1) if match else None
    if result.returncode != 0 or model is None or report is None:
        problems.append(f"clean run failed ({result.returncode}):\n{output}")
    else:
        bond_failures = [
            f
            for f in report["definitive_failures"]
            if f["type"] in ("bond-mode-mismatch", "asymmetric-bond-cable")
        ]
        if bond_failures:
            problems.append("clean run has bond failures:\n" + json.dumps(bond_failures, indent=2))
        _check_clean_bonds(unit_probe_outputs(model), bonded, problems)

    if not problems and model:
        target = bonded[0]
        for fault_name, ftype, hint in BOND_FAULT_CASES:
            log(f"verify bond: {fault_name} fault on {target}")
            cmd_fault(fault_name, [target])
            result = network_tester_run(f"--reuse-model {model} --wait-timeout 900")
            out = result.stdout + result.stderr
            rep = report_from_output(out)
            if rep is None:
                problems.append(f"{fault_name} run produced no report:\n{out}")
            else:
                matching = [
                    f
                    for f in rep["definitive_failures"]
                    if f["type"] == ftype and f.get("node") == target and hint in f.get("hint", "")
                ]
                if not matching:
                    problems.append(
                        f"{fault_name}: no {ftype} finding for {target} with hint "
                        f"'{hint}':\n" + json.dumps(rep["definitive_failures"], indent=2)
                    )
                if result.returncode != 1:
                    problems.append(f"{fault_name} run exited {result.returncode}, expected 1")
            log(f"verify bond: clearing {fault_name}")
            clear_faults()

    if model:
        log("verify bond: destroying kept model")
        vm_run(f"juju destroy-model --no-prompt --force --timeout 15m {model}", check=False)
        wait_nodes_ready()

    if problems:
        for problem in problems:
            log(f"FAIL: {problem}")
        sys.exit(1)
    log("verify bond: PASS (clean LACP, bond-static, bond-passive, bond-swap)")


def _bgp_passes(report):
    return [e for e in report.get("passed_checks", []) if e["type"] == "bgp-reachability"]


def _mtu_observations(report):
    return [
        o
        for o in report.get("observations", [])
        if o["type"] == "cross-rack-mtu" and o.get("observed_path_mtu_bytes")
    ]


def verify_multirack():
    """Stage 7 gate: clean cross-rack run plus bgp-down, mtu, rep-wrong-vlan."""
    charm_name = ensure_charm_packed()
    sync_tree()
    ensure_juju()
    destroy_test_models()
    clear_faults()
    problems = []
    deploy_args = f"--charm charm/{charm_name} --cloud {MAAS_CLOUD} --wait-timeout 2400"

    log("verify multirack: clean run (model kept for fault re-triggers)")
    result = network_tester_run(f"--all --keep-model --verbose {deploy_args}")
    output = result.stdout + result.stderr
    match = re.search(r"Model (network-test-\S+) kept", output)
    report = report_from_output(output)
    model = match.group(1) if match else None
    if model is None or report is None:
        problems.append(f"clean run failed ({result.returncode}):\n{output}")
    else:
        if report["definitive_failures"] or report["inferred_failures"]:
            problems.append(
                "clean run has failures:\n"
                + json.dumps(report["definitive_failures"] + report["inferred_failures"], indent=2)
            )
        if len(_bgp_passes(report)) < 2:
            problems.append(
                f"clean run: expected cross-rack BGP reachable both directions, got "
                f"{len(_bgp_passes(report))} passes"
            )
        mtus = [o["observed_path_mtu_bytes"] for o in _mtu_observations(report)]
        if not mtus:
            problems.append("clean run: no cross-rack MTU observations")
        elif not all(1400 <= m <= 1600 for m in mtus):
            problems.append(f"clean run: MTU observations not ~1500: {mtus}")

    if not problems and model:
        problems += _verify_multirack_faults(model)

    if model:
        log("verify multirack: destroying kept model")
        vm_run(f"juju destroy-model --no-prompt --force --timeout 15m {model}", check=False)
        wait_nodes_ready()

    if problems:
        for problem in problems:
            log(f"FAIL: {problem}")
        sys.exit(1)
    log("verify multirack: PASS (clean cross-rack, bgp-down, mtu, rep-wrong-vlan)")


def _verify_multirack_faults(model):
    problems = []

    log("verify multirack: bgp-down fault")
    cmd_fault("bgp-down", [])
    rep = report_from_output(
        (network_tester_run(f"--reuse-model {model} --wait-timeout 1200").stdout or "")
    )
    if rep is None:
        problems.append("bgp-down: no report")
    else:
        inferred = rep["inferred_failures"]
        tor = [f for f in inferred if f.get("type") == "likely-bgp-failure"]
        if len(inferred) != 1 or not tor:
            problems.append(
                "bgp-down: expected one inferred likely-bgp-failure rack-pair entry:\n"
                + json.dumps(inferred, indent=2)
            )
    clear_faults()

    log("verify multirack: mtu 1400 fault")
    cmd_fault("mtu", ["1400"])
    rep = report_from_output(
        (network_tester_run(f"--reuse-model {model} --wait-timeout 1200").stdout or "")
    )
    if rep is None:
        problems.append("mtu: no report")
    else:
        mtus = [o["observed_path_mtu_bytes"] for o in _mtu_observations(rep)]
        if not mtus or not all(m == 1400 for m in mtus):
            problems.append(f"mtu 1400: expected 1400 observations both directions, got {mtus}")
    clear_faults()

    log("verify multirack: rep-wrong-vlan fault")
    cmd_fault("rep-wrong-vlan", [])
    # --verbose so the report carries passed_checks: with two data nodes per
    # rack the reverse direction reaches the broken rep's rack via the BGP
    # fallback target, and we assert that fallback reachability explicitly.
    rep = report_from_output(
        (network_tester_run(f"--reuse-model {model} --verbose --wait-timeout 1200").stdout or "")
    )
    if rep is None:
        problems.append("rep-wrong-vlan: no report")
    else:
        gated = [
            e
            for e in rep["inconclusive_checks"]
            if e["type"] == "bgp-reachability" and "phase-1 failure" in e.get("note", "")
        ]
        # The broken node is rack-1's representative. Both racks have a second
        # data node, so the reverse direction (rack-2 -> rack-1) does not fail:
        # the BGP fallback target answers, the rack-pair stays reachable (a
        # passed bgp-reachability check), and the report flags the dead rep with
        # a target-representative-unreachable warning. Rack-1's own outbound is
        # phase-1 gated to inconclusive.
        fallback_warn = [
            w for w in rep["warnings"] if w["type"] == "target-representative-unreachable"
        ]
        fallback_reachable = _bgp_passes(rep)
        if not gated:
            problems.append(
                "rep-wrong-vlan: expected rack-1 outbound BGP gated to inconclusive:\n"
                + json.dumps(rep["inconclusive_checks"], indent=2)
            )
        if not fallback_warn:
            problems.append(
                "rep-wrong-vlan: expected a target-representative-unreachable (fallback) "
                "warning:\n" + json.dumps(rep["warnings"], indent=2)
            )
        if not fallback_reachable:
            problems.append(
                "rep-wrong-vlan: expected the reverse rack-pair reachable via the fallback "
                "target (a passed bgp-reachability check):\n"
                + json.dumps(rep.get("passed_checks", []), indent=2)
            )
    clear_faults()
    return problems


def verify_timeout():
    """Phase 8 gate: a probe-timeout too small to finish yields partial timeout
    output, units back at active/idle, and cross-rack work classified as
    inconclusive rather than missing or failed.

    Phase 1 holds a fixed ~35s capture window (the LACP slow-rate floor and the
    30s ARP cap), independent of fabric health. On a healthy testbed the
    cross-rack MTU/BGP phases would otherwise finish in a second or two
    (reachable paths answer immediately), so a probe-timeout below the phase-1
    floor reliably cuts the run before the cross-rack phases start. The runner
    writes partial output with status timeout; the charm still returns the unit
    to active/idle ("probe <id> complete"); the report derives the unattempted
    representative-sampled rack-pairs from the topology and lists them as
    inconclusive (design D14/D16).
    """
    charm_name = ensure_charm_packed()
    sync_tree()
    ensure_juju()
    destroy_test_models()
    clear_faults()
    problems = []
    deploy_args = f"--charm charm/{charm_name} --cloud {MAAS_CLOUD} --wait-timeout 2400"

    # A single run with a low --probe-timeout (set via the CLI, i.e. libjuju, so
    # there is no juju-CLI model-cache dependency on a freshly created model).
    log("verify timeout: deploy + probe with probe-timeout=30 (below the phase-1 floor)")
    result = network_tester_run(f"--all --probe-timeout 30 --keep-model --verbose {deploy_args}")
    output = result.stdout + result.stderr
    match = re.search(r"Model (network-test-\S+) kept", output)
    model = match.group(1) if match else None
    report = report_from_output(output)
    if report is None:
        problems.append(f"timeout run failed ({result.returncode}): no report:\n{output}")
    else:
        inconclusive = [
            e for e in report.get("inconclusive_checks", []) if e.get("type") == "bgp-reachability"
        ]
        if not inconclusive:
            problems.append(
                "timeout run: expected unattempted cross-rack checks classified "
                "inconclusive:\n" + json.dumps(report.get("inconclusive_checks", []), indent=2)
            )
        failures = report.get("definitive_failures", []) + report.get("inferred_failures", [])
        if failures:
            problems.append(
                "timeout run: cross-rack timeout misclassified as failure:\n"
                + json.dumps(failures, indent=2)
            )
        if report.get("missing_nodes"):
            problems.append(
                "timeout run: cross-rack timeout misclassified as missing nodes:\n"
                + json.dumps(report["missing_nodes"], indent=2)
            )

    if model:
        log("verify timeout: destroying kept model")
        vm_run(f"juju destroy-model --no-prompt --force --timeout 15m {model}", check=False)
        # Juju deletes (not just releases) the MAAS machines on destroy-model:
        # the controller issues op=release then DELETE /machines/<id>, and MAAS
        # decomposes the VM-host (pod) machines ("Decomposing machine" in the
        # region log). So the nodes do not return to Ready - they are gone. Wait
        # for the model to clear; a subsequent `up` re-composes the nodes.
        wait_for(
            f"model {model} to be destroyed",
            lambda: not vm_ok(f"juju show-model {model} >/dev/null 2>&1"),
            timeout=600,
            interval=10,
        )

    if problems:
        for problem in problems:
            log(f"FAIL: {problem}")
        sys.exit(1)
    log("verify timeout: PASS (low probe-timeout -> partial timeout, inconclusive cross-rack)")


# Writes a synthetic 200-node / 20-rack topology resource inside the VM. The
