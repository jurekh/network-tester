import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import time
from pathlib import Path

import yaml

TESTBED_DIR = Path(__file__).resolve().parent
REPO_ROOT = TESTBED_DIR.parent
CONFIG = yaml.safe_load((TESTBED_DIR / "topology.yaml").read_text())

VM = CONFIG["vm"]["name"]
PXE = CONFIG["pxe"]
VLANS = CONFIG.get("vlans", {})
MAAS_CFG = CONFIG["maas"]
MAAS_URL = f"http://{PXE['gateway']}:5240/MAAS"
VM_TREE = "/root/network-tester"

# Rack 2 and ToR routers (stage 7); absent on a single-rack topology.
RACK2 = CONFIG.get("rack2")
ROUTERS = CONFIG.get("routers")


def rack_net(rack):
    """Bridge / pxe / vlans for a rack name (rack-1 is the top-level network).

    `bridge` is the rack's OVS bridge that carries the tagged VLANs and bonds
    (where node mgmt/bond NICs live after the first commission), not the Linux
    PXE/compose bridge.
    """
    if rack == "rack-1" or RACK2 is None:
        return {"bridge": PXE["ovs_bridge"], "pxe": PXE, "vlans": VLANS, "pxe_access_vlan": None}
    return {
        "bridge": RACK2["bridge"],
        "pxe": RACK2["pxe"],
        "vlans": RACK2["vlans"],
        # OVS access VLAN that isolates the untagged rack-2 PXE segment from the
        # tagged data VLAN on the shared OVS bridge (rack 1's PXE is a separate
        # Linux bridge, so it needs none).
        "pxe_access_vlan": RACK2.get("pxe_access_vlan"),
    }


def all_racks():
    """Rack names present in the topology, rack-1 first."""
    return list(CONFIG["racks"].keys())


