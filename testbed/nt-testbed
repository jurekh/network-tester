# --- faults -------------------------------------------------------------------


def _addressed_links(interface):
    """Links that configure addressing. MAAS represents a link-less interface
    with a mode=link_up entry that still references the subnet; it assigns no
    address and does not count as configuration."""
    return [
        ln for ln in interface.get("links", []) if ln.get("subnet") and ln.get("mode") != "link_up"
    ]


def fault_incomplete_config(args):
    """Remove the subnet link from a node's boot interface via the MAAS API."""
    if len(args) != 1:
        fatal("usage: nt-testbed fault incomplete-config <hostname>")
    hostname = args[0]
    machines = maas_json("machines read")
    machine = next((m for m in machines if m["hostname"] == hostname), None)
    if machine is None:
        fatal(f"no machine named {hostname}; have: {sorted(m['hostname'] for m in machines)}")
    boot_id = (machine.get("boot_interface") or {}).get("id")
    interface = next(i for i in machine["interface_set"] if i["id"] == boot_id)
    removed = 0
    for link in _addressed_links(interface):
        maas_json(
            f"interface unlink-subnet {machine['system_id']} {interface['id']} id={link['id']}"
        )
        removed += 1
    if removed:
        log(
            f"fault injected: removed {removed} subnet link(s) from {hostname} {interface['name']}"
        )
    else:
        log(f"{hostname} {interface['name']} already has no addressed subnet links")


def clear_incomplete_config():
    """Restore VLAN attachments and STATIC links from topology.yaml."""
    ensure_addressing()


def _node_tagged_nics(node):
    """(index, nic, tag) for each NIC of a node that has a VLAN tag."""
    vlans = node_net(node)["vlans"]
    out = []
    for idx, nic in enumerate(node.get("nics", [])):
        if nic.get("vlan"):
            out.append((idx, nic, vlans[nic["vlan"]]["tag"]))
    return out


def _ovs_port_for(host, device):
    """The OVS port name backing a running instance's NIC device."""
    port = vm_out(f"lxc config get {host} volatile.{device}.host_name", check=False)
    if not port:
        fatal(f"{host} {device} has no host-side port; is the instance running?")
    return port


def fault_wrong_vlan(args):
    """Retag a node's data NIC onto the oam VLAN (wrong segment)."""
    if len(args) != 1:
        fatal("usage: nt-testbed fault wrong-vlan <hostname>")
    hostname = args[0]
    node = next((n for n in expected_nodes() if n["hostname"] == hostname), None)
    if node is None:
        fatal(f"no node named {hostname} in topology.yaml")
    data = [(i, n, t) for i, n, t in _node_tagged_nics(node) if n["vlan"] == "data"]
    if not data:
        fatal(f"{hostname} has no data NIC to retag")
    idx, _nic, _tag = data[0]
    devices = sorted(inner_nic_devices(hostname))
    device = devices[idx]
    other_tag = node_net(node)["vlans"]["oam"]["tag"]
    vm_run(f"ovs-vsctl set port {_ovs_port_for(hostname, device)} tag={other_tag}")
    log(f"fault injected: {hostname} {device} retagged to VLAN {other_tag} (oam)")


def clear_wrong_vlan():
    """Restore configured OVS tags on all running nodes' NICs."""
    for node in expected_nodes():
        devices = sorted(inner_nic_devices(node["hostname"]))
        for idx, _nic, tag in _node_tagged_nics(node):
            if idx >= len(devices):
                continue
            port = vm_out(
                f"lxc config get {node['hostname']} volatile.{devices[idx]}.host_name",
                check=False,
            )
            if port:
                vm_run(f"ovs-vsctl set port {port} tag={tag}", check=False)


def _bond_node(args, cmd):
    """Resolve a single data node with a bond from a fault's args."""
    if len(args) != 1:
        fatal(f"usage: nt-testbed fault {cmd} <hostname>")
    host = args[0]
    node = next((n for n in expected_nodes() if n["hostname"] == host), None)
    if node is None or not node_bond(node):
        fatal(f"{host} is not a bonded data node in topology.yaml")
    return node


def _set_host_lacp_active(host, state, check=True):
    """Toggle the deployed node's kernel bond LACP activity (active/passive).

    lacp_active can only be changed while the bond is administratively down
    (the kernel rejects it on an up bond), so bounce the bond around the
    change. Idempotent: a no-op when the bond already has the wanted value, so
    clearing other faults does not needlessly bounce the bond.
    """
    bond = node_bond(next(n for n in expected_nodes() if n["hostname"] == host))["name"]
    # The bash -c argument is wrapped in single quotes below, so this script
    # must not contain single quotes; lacp_active reads "on 1"/"off 0" from
    # sysfs, so cut the first field with a double-quoted delimiter.
    script = (
        f'cur=$(cut -d" " -f1 /sys/class/net/{bond}/bonding/lacp_active 2>/dev/null); '
        f'[ "$cur" = "{state}" ] && exit 0; '
        f"ip link set {bond} down && ip link set {bond} type bond lacp_active {state} && "
        f"ip link set {bond} up"
    )
    vm_run("lxc exec " + host + " -- bash -c '" + script + "'", check=check)


def _pause_reconciler():
    """Stop the reconciler from reverting a fault-modified OVS bond."""
    vm_run(f"touch {BOND_PAUSE_FLAG}")


def fault_bond_static(args):
    """Disable LACP on a node's OVS bond: the switch behaves static while the
    host still expects 802.3ad, so no PDUs arrive -> bond-mode-mismatch."""
    node = _bond_node(args, "bond-static")
    _pause_reconciler()
    vm_run(f"ovs-vsctl set port {ovs_bond_name(node['hostname'])} lacp=off")
    log(f"fault injected: {node['hostname']} OVS bond LACP disabled (static switch)")


def fault_bond_passive(args):
    """Emulate the both-passive case: the host bond is LACP-passive and no PDUs
    arrive. The OVS bond's LACP is disabled (not just set passive): OVS keeps
    transmitting on an already-established session even when passive, so only
    lacp=off reliably silences it. The validator distinguishes this from a
    static switch by the host's lacp_active flag, giving the both-passive hint.
    """
    node = _bond_node(args, "bond-passive")
    host = node["hostname"]
    _pause_reconciler()
    vm_run(f"ovs-vsctl set port {ovs_bond_name(host)} lacp=off")
    _set_host_lacp_active(host, "off")
    log(f"fault injected: {host} host bond LACP-passive and switch silent (both-passive)")


# A distinct LACP system id for the "wrong switch" half of a cable swap so the
# node sees two different actor system ids across its bond members.
WRONG_SWITCH_SYSTEM_ID = "02:00:00:00:00:7e"


def fault_bond_swap(args):
    """Move one bond member into a second OVS bond with a different LACP system
    id, emulating a cable plugged into the wrong switch -> asymmetric-bond-cable.

    OVS bonds require at least two interfaces, so each half is padded with an
    internal dummy interface that does not affect LACP toward the node.
    """
    node = _bond_node(args, "bond-swap")
    host = node["hostname"]
    bridge = PXE["ovs_bridge"]
    tag = VLANS[node_bond(node)["vlan"]]["tag"]
    ports = _bond_member_ports(node)
    if len(ports) < 2:
        fatal(f"{host} bond has fewer than two members; cannot emulate a swap")
    _pause_reconciler()
    name = ovs_bond_name(host)
    extras = swap_extra_names(host)
    wrong, pad_a, pad_b = extras["wrong"], extras["pad_a"], extras["pad_b"]
    vm_run(f"ovs-vsctl --if-exists del-port {bridge} {name}")
    vm_run(
        f"ovs-vsctl add-bond {bridge} {name} {ports[0]} {pad_a} "
        f"-- set interface {pad_a} type=internal "
        f"-- set port {name} bond_mode=balance-tcp lacp=active "
        f"other_config:lacp-time=slow tag={tag}"
    )
    vm_run(
        f"ovs-vsctl add-bond {bridge} {wrong} {ports[1]} {pad_b} "
        f"-- set interface {pad_b} type=internal "
        f"-- set port {wrong} bond_mode=balance-tcp lacp=active "
        f"other_config:lacp-time=slow other_config:lacp-system-id={WRONG_SWITCH_SYSTEM_ID} "
        f"tag={tag}"
    )
    log(f"fault injected: {host} bond member {ports[1]} moved to wrong-switch bond {wrong}")


def clear_bond():
    """Restore unified OVS bonds and host LACP activity from topology.yaml.

    Rebuilds each running node's bond synchronously (the fault sequence runs
    while the nodes are deployed); for powered-off nodes it just clears any
    fault-only bonds and lets the reconciler rebuild on the next boot. The
    reconciler stays paused until every node is restored, then resumes.

    Pause first: build_ovs_bond del-ports each bond before re-adding it, and an
    unpaused reconciler would see the transient mismatch and rebuild the bond
    itself, racing the add-bond ("port already exists"). This clear runs after
    every fault, including non-bond faults (bgp-down, mtu) that leave the
    reconciler active, so the pause cannot be left to the fault injectors.
    """
    _pause_reconciler()
    bridge = PXE["ovs_bridge"]
    for node in expected_nodes():
        if not node_bond(node):
            continue
        host = node["hostname"]
        name = ovs_bond_name(host)
        if vm_ok(f"lxc exec {host} -- true"):
            build_ovs_bond(node)
            _set_host_lacp_active(host, "on", check=False)
        else:
            for extra in swap_extra_names(host).values():
                vm_run(f"ovs-vsctl --if-exists del-port {bridge} {extra}", check=False)
            vm_run(f"ovs-vsctl --if-exists set port {name} lacp=active", check=False)
    vm_run(f"rm -f {BOND_PAUSE_FLAG}", check=False)


def fault_bgp_down(args):
    """Shut down the rack-1 ToR's eBGP session toward rack 2 (likely-bgp-failure)."""
    if ROUTERS is None:
        fatal("no routers configured (single-rack topology)")
    cfg, peer = ROUTERS["rack-1"], ROUTERS["rack-2"]
    vtysh = " ".join(
        f"-c {shlex.quote(c)}"
        for c in (
            "conf t",
            f"router bgp {cfg['asn']}",
            f"neighbor {peer['link_ip']} shutdown",
            "end",
            "write memory",
        )
    )
    vm_run(f"lxc exec {cfg['name']} -- vtysh {vtysh}")
    log(f"fault injected: {cfg['name']} eBGP neighbor {peer['link_ip']} shut down")


def clear_bgp_down():
    if ROUTERS is None:
        return
    cfg, peer = ROUTERS["rack-1"], ROUTERS["rack-2"]
    if not vm_ok(f"lxc info {cfg['name']} >/dev/null 2>&1"):
        return
    vtysh = " ".join(
        f"-c {shlex.quote(c)}"
        for c in (
            "conf t",
            f"router bgp {cfg['asn']}",
            f"no neighbor {peer['link_ip']} shutdown",
            "end",
            "write memory",
        )
    )
    vm_run(f"lxc exec {cfg['name']} -- vtysh {vtysh}", check=False)


def fault_mtu(args):
    """Set the inter-rack link MTU on both ToR routers (default 1400)."""
    if ROUTERS is None:
        fatal("no routers configured (single-rack topology)")
    mtu = args[0] if args else "1400"
