        vm_run(f"lxc exec {ROUTERS[rack]['name']} -- ip link set eth2 mtu {mtu}")
    log(f"fault injected: inter-rack link MTU set to {mtu} on both ToRs")


def clear_mtu():
    if ROUTERS is None:
